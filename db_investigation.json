  {
    "nombre_funcion": "corregir_operacion_v3",
    "codigo_fuente": "CREATE OR REPLACE FUNCTION public.corregir_operacion_v3(p_input jsonb)\n RETURNS jsonb\n LANGUAGE plpgsql\nAS $function$\nDECLARE\n    -- Variables extraídas del JSON\n    v_operacion_id_raw text;\n    v_operacion_id_final text;\n    v_producto_busqueda text;\n    \n    v_nuevo_nombre text;\n    v_nuevo_precio numeric;\n    v_nueva_cantidad int;\n\n    -- Variables internas\n    v_tipo text;\n    v_item_id bigint;\n    v_total_nuevo numeric;\nBEGIN\n    -- 1. EXTRACCIÓN Y LIMPIEZA DE DATOS\n    -- Extraemos del JSON y convertimos vacíos ('') a NULL automáticamente\n    v_operacion_id_raw := NULLIF(TRIM(p_input->>'operacion_id'), '');\n    v_producto_busqueda := NULLIF(TRIM(p_input->>'detalle_a_corregir'), '');\n    \n    -- Extraemos datos anidados (nuevos_datos)\n    v_nuevo_nombre := NULLIF(TRIM(p_input->'nuevos_datos'->>'nombre'), '');\n    \n    -- Casting seguro a números (si viene null o vacío, queda null)\n    BEGIN\n        v_nuevo_precio := (p_input->'nuevos_datos'->>'precio_unitario')::numeric;\n    EXCEPTION WHEN OTHERS THEN\n        v_nuevo_precio := NULL; -- Si falla la conversión, lo dejamos null\n    END;\n\n    BEGIN\n        v_nueva_cantidad := (p_input->'nuevos_datos'->>'cantidad')::int;\n    EXCEPTION WHEN OTHERS THEN\n        v_nueva_cantidad := NULL;\n    END;\n\n    -- 2. RESOLVER ID \"ULTIMA\"\n    IF v_operacion_id_raw = 'ULTIMA' THEN\n        SELECT operacion_id INTO v_operacion_id_final\n        FROM public.historial_bot \n        WHERE estado = 'EXITO' \n        ORDER BY log_id DESC \n        LIMIT 1;\n\n        IF v_operacion_id_final IS NULL THEN\n            RETURN jsonb_build_object('success', false, 'error', 'No se encontró ninguna operación anterior para corregir.');\n        END IF;\n    ELSE\n        v_operacion_id_final := v_operacion_id_raw;\n    END IF;\n\n    -- 3. DETECTAR TIPO (VENTA, COMPRA, RESERVA)\n    v_tipo := split_part(v_operacion_id_final, '_', 1);\n\n    -- 4. LÓGICA DE ACTUALIZACIÓN (Igual que antes, pero usando las vars limpias)\n    \n    -- === CASO VENTA ===\n    IF v_tipo = 'VENTA' THEN\n        SELECT id INTO v_item_id FROM public.ventas_detalles \n        WHERE venta_id = v_operacion_id_final AND producto ILIKE '%' || v_producto_busqueda || '%' LIMIT 1;\n\n        IF v_item_id IS NULL THEN RETURN jsonb_build_object('success', false, 'error', 'Producto \"'||v_producto_busqueda||'\" no encontrado en Venta '||v_operacion_id_final); END IF;\n\n        UPDATE public.ventas_detalles\n        SET \n            producto = COALESCE(v_nuevo_nombre, producto),\n            precio_unitario = COALESCE(v_nuevo_precio, precio_unitario),\n            cantidad = COALESCE(v_nueva_cantidad, cantidad),\n            subtotal = (COALESCE(v_nueva_cantidad, cantidad) * COALESCE(v_nuevo_precio, precio_unitario))\n        WHERE id = v_item_id;\n\n        SELECT COALESCE(SUM(subtotal),0) INTO v_total_nuevo FROM public.ventas_detalles WHERE venta_id = v_operacion_id_final;\n        UPDATE public.ventas SET total = v_total_nuevo WHERE venta_id = v_operacion_id_final;\n        UPDATE public.movimientos_dinero SET monto = v_total_nuevo WHERE referencia_id = v_operacion_id_final;\n\n    -- === CASO COMPRA ===\n    ELSIF v_tipo = 'COMPRA' THEN\n        SELECT id INTO v_item_id FROM public.compras_detalles \n        WHERE compra_id = v_operacion_id_final AND producto ILIKE '%' || v_producto_busqueda || '%' LIMIT 1;\n\n        IF v_item_id IS NULL THEN RETURN jsonb_build_object('success', false, 'error', 'Producto no encontrado en Compra'); END IF;\n\n        UPDATE public.compras_detalles\n        SET \n            producto = COALESCE(v_nuevo_nombre, producto),\n            precio_unitario = COALESCE(v_nuevo_precio, precio_unitario),\n            cantidad = COALESCE(v_nueva_cantidad, cantidad),\n            subtotal = (COALESCE(v_nueva_cantidad, cantidad) * COALESCE(v_nuevo_precio, precio_unitario))\n        WHERE id = v_item_id;\n\n        SELECT COALESCE(SUM(subtotal),0) INTO v_total_nuevo FROM public.compras_detalles WHERE compra_id = v_operacion_id_final;\n        UPDATE public.compras SET total = v_total_nuevo WHERE compra_id = v_operacion_id_final;\n        UPDATE public.movimientos_dinero SET monto = v_total_nuevo WHERE referencia_id = v_operacion_id_final;\n\n    -- === CASO RESERVA ===\n    ELSIF v_tipo = 'RESERVA' THEN\n        SELECT id INTO v_item_id FROM public.reservas_detalles \n        WHERE reserva_id = v_operacion_id_final AND producto ILIKE '%' || v_producto_busqueda || '%' LIMIT 1;\n\n        IF v_item_id IS NULL THEN RETURN jsonb_build_object('success', false, 'error', 'Producto no encontrado en Reserva'); END IF;\n\n        UPDATE public.reservas_detalles\n        SET \n            producto = COALESCE(v_nuevo_nombre, producto),\n            precio_unitario = COALESCE(v_nuevo_precio, precio_unitario),\n            cantidad = COALESCE(v_nueva_cantidad, cantidad),\n            subtotal = (COALESCE(v_nueva_cantidad, cantidad) * COALESCE(v_nuevo_precio, precio_unitario))\n        WHERE id = v_item_id;\n\n        SELECT COALESCE(SUM(subtotal),0) INTO v_total_nuevo FROM public.reservas_detalles WHERE reserva_id = v_operacion_id_final;\n        UPDATE public.reservas SET total = v_total_nuevo WHERE reserva_id = v_operacion_id_final;\n\n    ELSE\n        RETURN jsonb_build_object('success', false, 'error', 'Tipo de operación desconocido: ' || v_operacion_id_final);\n    END IF;\n\n    -- 5. RETORNO EXITOSO\n    RETURN jsonb_build_object(\n        'success', true, \n        'mensaje', '✅ Corrección aplicada a ' || v_operacion_id_final || '. Nuevo Total: $' || v_total_nuevo,\n        'id_final', v_operacion_id_final\n    );\n\nEXCEPTION WHEN OTHERS THEN\n    RETURN jsonb_build_object('success', false, 'error', SQLERRM);\nEND;\n$function$\n"
  },
  {
    "nombre_funcion": "corregir_operacion_v16",
    "codigo_fuente": "CREATE OR REPLACE FUNCTION public.corregir_operacion_v16(p_input jsonb)\n RETURNS jsonb\n LANGUAGE plpgsql\nAS $function$\r\nDECLARE\r\n    -- Variables de estructura\r\n    v_input_norm jsonb;\r\n    v_id_final text;\r\n    v_tipo text;\r\n    v_items_json jsonb;\r\n    v_pagos_json jsonb;\r\n    \r\n    -- Cursores y variables de Items\r\n    rec_item record;\r\n    v_item_id bigint;\r\n    v_old_n text; v_old_q numeric; v_old_p numeric;\r\n    v_new_n text; v_new_q numeric; v_new_p numeric;\r\n    \r\n    -- Variables de Pagos\r\n    rec_pago record;\r\n    v_mov_id text;\r\n    v_m_ant numeric; v_m_nue numeric;\r\n    v_met_ant text; v_met_nue text;\r\n    \r\n    -- Reporte y Totales\r\n    v_reporte_detallado text := '';\r\n    v_total_recal numeric := 0;\r\n    v_cambios_realizados int := 0;\r\n    v_salto text := chr(10);\r\nBEGIN\r\n    -- 0. NORMALIZAR ENTRADA\r\n    v_input_norm := CASE WHEN jsonb_typeof(p_input) = 'array' THEN p_input->0 ELSE p_input END;\r\n\r\n    -- 1. IDENTIFICAR OPERACIÓN\r\n    v_id_final := NULLIF(TRIM(v_input_norm->>'id_final'), '');\r\n    IF v_id_final IS NULL THEN RETURN jsonb_build_object('success', false, 'error', 'ID no especificado.'); END IF;\r\n\r\n    IF v_id_final = 'ULTIMA' THEN\r\n        SELECT operacion_id INTO v_id_final FROM public.historial_bot WHERE estado = 'EXITO' AND operacion_id IS NOT NULL ORDER BY log_id DESC LIMIT 1;\r\n        IF v_id_final IS NULL THEN RETURN jsonb_build_object('success', false, 'error', 'No hay historial.'); END IF;\r\n    END IF;\r\n\r\n    v_tipo := split_part(v_id_final, '_', 1);\r\n    v_reporte_detallado := '🛠️ *Corrección en ' || v_id_final || '*' || v_salto;\r\n\r\n    -- 2. PROCESAR PRODUCTOS (ITEMS)\r\n    v_items_json := v_input_norm->'items';\r\n    IF v_items_json IS NOT NULL AND jsonb_array_length(v_items_json) > 0 THEN\r\n        FOR rec_item IN SELECT * FROM jsonb_array_elements(v_items_json) LOOP\r\n            \r\n            -- BUSCAR DATA ACTUAL SEGÚN EL TIPO DE OPERACIÓN\r\n            IF v_tipo IN ('RESERVA', 'RES') THEN\r\n                SELECT id, producto, cantidad, precio_unitario INTO v_item_id, v_old_n, v_old_q, v_old_p\r\n                FROM public.reservas_detalles WHERE reserva_id = v_id_final AND producto ILIKE '%' || (rec_item.value->>'producto') || '%' LIMIT 1;\r\n            ELSIF v_tipo = 'COMPRA' THEN\r\n                SELECT id, producto, cantidad, precio_unitario INTO v_item_id, v_old_n, v_old_q, v_old_p\r\n                FROM public.compras_detalles WHERE compra_id = v_id_final AND producto ILIKE '%' || (rec_item.value->>'producto') || '%' LIMIT 1;\r\n            ELSE -- VENTA\r\n                SELECT id, producto, cantidad::numeric, precio_unitario INTO v_item_id, v_old_n, v_old_q, v_old_p\r\n                FROM public.ventas_detalles WHERE venta_id = v_id_final AND producto ILIKE '%' || (rec_item.value->>'producto') || '%' LIMIT 1;\r\n            END IF;\r\n\r\n            IF v_item_id IS NOT NULL THEN\r\n                v_new_n := COALESCE(NULLIF(TRIM(rec_item.value->>'nuevo_nombre'), ''), v_old_n);\r\n                v_new_q := COALESCE((rec_item.value->>'nueva_cantidad')::numeric, v_old_q);\r\n                v_new_p := COALESCE((rec_item.value->>'nuevo_precio')::numeric, v_old_p);\r\n\r\n                -- Detectar si hay cambios reales para reportar\r\n                IF (v_new_n != v_old_n OR v_new_q != v_old_q OR v_new_p != v_old_p) THEN\r\n                    v_reporte_detallado := v_reporte_detallado || v_salto || '📦 *' || v_old_n || '*:';\r\n                    IF v_new_n != v_old_n THEN v_reporte_detallado := v_reporte_detallado || v_salto || '  • Nombre: ' || v_old_n || ' ➔ ' || v_new_n; END IF;\r\n                    IF v_new_q != v_old_q THEN v_reporte_detallado := v_reporte_detallado || v_salto || '  • Cant: ' || v_old_q || ' ➔ ' || v_new_q; END IF;\r\n                    IF v_new_p != v_old_p THEN v_reporte_detallado := v_reporte_detallado || v_salto || '  • Precio: $' || v_old_p || ' ➔ $' || v_new_p; END IF;\r\n\r\n                    -- APLICAR LOS CAMBIOS EN LA TABLA QUE CORRESPONDA\r\n                    IF v_tipo IN ('RESERVA', 'RES') THEN\r\n                        UPDATE public.reservas_detalles SET producto = v_new_n, cantidad = v_new_q, precio_unitario = v_new_p, subtotal = (v_new_q * v_new_p) WHERE id = v_item_id;\r\n                    ELSIF v_tipo = 'COMPRA' THEN\r\n                        UPDATE public.compras_detalles SET producto = v_new_n, cantidad = v_new_q, precio_unitario = v_new_p, subtotal = (v_new_q * v_new_p) WHERE id = v_item_id;\r\n                    ELSE\r\n                        UPDATE public.ventas_detalles SET producto = v_new_n, cantidad = v_new_q::int, precio_unitario = v_new_p, subtotal = (v_new_q * v_new_p) WHERE id = v_item_id;\r\n                    END IF;\r\n\r\n                    -- Sincronizar el nombre en los movimientos de stock\r\n                    IF v_new_n != v_old_n THEN\r\n                        UPDATE public.stock_movimientos SET producto = v_new_n WHERE referencia_id = v_id_final AND producto = v_old_n;\r\n                    END IF;\r\n                    v_cambios_realizados := v_cambios_realizados + 1;\r\n                END IF;\r\n            END IF;\r\n        END LOOP;\r\n    END IF;\r\n\r\n    -- 3. PROCESAR PAGOS\r\n    v_pagos_json := v_input_norm->'pagos';\r\n    IF v_pagos_json IS NOT NULL AND jsonb_array_length(v_pagos_json) > 0 THEN\r\n        FOR rec_pago IN SELECT * FROM jsonb_array_elements(v_pagos_json) LOOP\r\n            v_m_ant := (rec_pago.value->>'monto_anterior')::numeric;\r\n            v_m_nue := (rec_pago.value->>'nuevo_monto')::numeric;\r\n            v_met_nue := NULLIF(TRIM(rec_pago.value->>'nuevo_metodo'), '');\r\n\r\n            SELECT movimiento_id, metodo INTO v_mov_id, v_met_ant FROM public.movimientos_dinero\r\n            WHERE referencia_id = v_id_final AND monto::numeric = v_m_ant ORDER BY fecha DESC LIMIT 1;\r\n\r\n            IF v_mov_id IS NOT NULL AND (v_m_nue != v_m_ant OR (v_met_nue IS NOT NULL AND v_met_nue != v_met_ant)) THEN\r\n                v_reporte_detallado := v_reporte_detallado || v_salto || v_salto || '💵 *Pago Corregido*:';\r\n                IF v_m_nue != v_m_ant THEN v_reporte_detallado := v_reporte_detallado || v_salto || '  • Monto: $' || v_m_ant || ' ➔ $' || v_m_nue; END IF;\r\n                IF v_met_nue IS NOT NULL AND v_met_nue != v_met_ant THEN v_reporte_detallado := v_reporte_detallado || v_salto || '  • Método: ' || v_met_ant || ' ➔ ' || v_met_nue; END IF;\r\n\r\n                IF v_m_nue = 0 THEN DELETE FROM public.movimientos_dinero WHERE movimiento_id = v_mov_id;\r\n                ELSE UPDATE public.movimientos_dinero SET monto = v_m_nue, metodo = COALESCE(v_met_nue, metodo) WHERE movimiento_id = v_mov_id;\r\n                END IF;\r\n                v_cambios_realizados := v_cambios_realizados + 1;\r\n            END IF;\r\n        END LOOP;\r\n    END IF;\r\n\r\n    -- 4. RECALCULO DE CABECERAS (Totales de la operación)\r\n    IF v_tipo IN ('RESERVA', 'RES') THEN\r\n        PERFORM public.recalcular_reserva(v_id_final);\r\n        SELECT saldo_pendiente INTO v_total_recal FROM public.reservas WHERE reserva_id = v_id_final;\r\n        v_reporte_detallado := v_reporte_detallado || v_salto || v_salto || '💰 *Nuevo Saldo Pendiente: $' || v_total_recal || '*';\r\n    ELSIF v_tipo = 'COMPRA' THEN\r\n        SELECT SUM(subtotal::numeric) INTO v_total_recal FROM public.compras_detalles WHERE compra_id = v_id_final;\r\n        UPDATE public.compras SET total_compra = v_total_recal WHERE compra_id = v_id_final;\r\n        v_reporte_detallado := v_reporte_detallado || v_salto || v_salto || '💰 *Nuevo Total Compra: $' || v_total_recal || '*';\r\n    ELSE\r\n        SELECT COALESCE(SUM(subtotal), 0) INTO v_total_recal FROM public.ventas_detalles WHERE venta_id = v_id_final;\r\n        UPDATE public.ventas SET total_venta = v_total_recal WHERE venta_id = v_id_final;\r\n        v_reporte_detallado := v_reporte_detallado || v_salto || v_salto || '💰 *Nuevo Total Venta: $' || v_total_recal || '*';\r\n    END IF;\r\n\r\n    IF v_cambios_realizados = 0 THEN\r\n        v_reporte_detallado := '⚠️ No se detectaron cambios reales para aplicar.';\r\n    END IF;\r\n\r\n    -- RETORNO RESTAURADO A FORMATO V14\r\n    RETURN jsonb_build_object(\r\n        'success', true, \r\n        'mensaje', v_reporte_detallado,\r\n        'detalles', jsonb_build_object(\r\n            'items', v_cambios_realizados,\r\n            'pagos', v_cambios_realizados,\r\n            'id', v_id_final\r\n        )\r\n    );\r\nEND;\r\n$function$\n"
  },
  {
    "nombre_funcion": "renombrar_producto_global",
    "codigo_fuente": "CREATE OR REPLACE FUNCTION public.renombrar_producto_global(p_nombre_viejo text, p_nombre_nuevo text)\n RETURNS jsonb\n LANGUAGE plpgsql\nAS $function$\r\nDECLARE\r\n    v_old text;\r\n    v_new text;\r\n    v_count_ventas int;\r\n    v_count_compras int;\r\n    v_count_stock int;\r\n    v_count_reservas int;\r\n    v_msg text;\r\nBEGIN\r\n    -- 1. Normalización (Para asegurar que coincida con tu lógica de triggers)\r\n    v_old := public.normalizar_texto(p_nombre_viejo);\r\n    v_new := public.normalizar_texto(p_nombre_nuevo);\r\n\r\n    -- Validación básica\r\n    IF v_old = v_new THEN\r\n        RETURN jsonb_build_object('success', false, 'error', 'El nombre nuevo es igual al viejo.');\r\n    END IF;\r\n\r\n    IF NOT EXISTS (SELECT 1 FROM public.productos WHERE nombre = v_old) THEN\r\n        RETURN jsonb_build_object('success', false, 'error', 'El producto original no existe: ' || v_old);\r\n    END IF;\r\n\r\n    -- ==============================================================================\r\n    -- 2. APAGAR TRIGGERS (Modo Silencioso)\r\n    -- Evitamos que el sistema intente \"aprender\" o recalcular stock por cada fila que cambiamos\r\n    -- ==============================================================================\r\n    ALTER TABLE public.ventas_detalles DISABLE TRIGGER trg_auto_learning_ventas;\r\n    ALTER TABLE public.compras_detalles DISABLE TRIGGER trg_auto_learning_compras;\r\n    ALTER TABLE public.stock_movimientos DISABLE TRIGGER trg_auto_stock_movimientos;\r\n\r\n    -- ==============================================================================\r\n    -- 3. ACTUALIZAR TABLAS TRANSACCIONALES (Historial)\r\n    -- ==============================================================================\r\n    \r\n    -- Ventas\r\n    WITH rows AS (\r\n        UPDATE public.ventas_detalles SET producto = v_new WHERE producto = v_old RETURNING 1\r\n    ) SELECT count(*) INTO v_count_ventas FROM rows;\r\n\r\n    -- Compras\r\n    WITH rows AS (\r\n        UPDATE public.compras_detalles SET producto = v_new WHERE producto = v_old RETURNING 1\r\n    ) SELECT count(*) INTO v_count_compras FROM rows;\r\n\r\n    -- Reservas\r\n    WITH rows AS (\r\n        UPDATE public.reservas_detalles SET producto = v_new WHERE producto = v_old RETURNING 1\r\n    ) SELECT count(*) INTO v_count_reservas FROM rows;\r\n\r\n    -- Stock Movimientos\r\n    WITH rows AS (\r\n        UPDATE public.stock_movimientos SET producto = v_new WHERE producto = v_old RETURNING 1\r\n    ) SELECT count(*) INTO v_count_stock FROM rows;\r\n\r\n    -- ==============================================================================\r\n    -- 4. ACTUALIZAR TABLA MAESTRA (Productos)\r\n    -- ==============================================================================\r\n    \r\n    -- Escenario A: El producto nuevo YA EXISTE (Fusión)\r\n    IF EXISTS (SELECT 1 FROM public.productos WHERE nombre = v_new) THEN\r\n        -- Como ya movimos el historial, solo queda borrar el viejo.\r\n        -- Opcional: Podrías querer sumar el stock del viejo al nuevo, pero es arriesgado \r\n        -- si el stock viejo estaba mal. Asumimos que el stock válido es el del destino.\r\n        DELETE FROM public.productos WHERE nombre = v_old;\r\n        v_msg := 'FUSIÓN: Se movió el historial de \"' || v_old || '\" a \"' || v_new || '\" (que ya existía).';\r\n    \r\n    -- Escenario B: El producto nuevo NO EXISTE (Renombrado Puro)\r\n    ELSE\r\n        UPDATE public.productos \r\n        SET nombre = v_new, fecha_actualizacion = NOW() \r\n        WHERE nombre = v_old;\r\n        v_msg := 'RENOMBRADO: Se cambió el nombre de \"' || v_old || '\" a \"' || v_new || '\".';\r\n    END IF;\r\n\r\n    -- ==============================================================================\r\n    -- 5. REENCENDER TRIGGERS\r\n    -- ==============================================================================\r\n    ALTER TABLE public.ventas_detalles ENABLE TRIGGER trg_auto_learning_ventas;\r\n    ALTER TABLE public.compras_detalles ENABLE TRIGGER trg_auto_learning_compras;\r\n    ALTER TABLE public.stock_movimientos ENABLE TRIGGER trg_auto_stock_movimientos;\r\n\r\n    RETURN jsonb_build_object(\r\n        'success', true, \r\n        'mensaje', v_msg,\r\n        'cambios', jsonb_build_object(\r\n            'ventas_afectadas', v_count_ventas,\r\n            'compras_afectadas', v_count_compras,\r\n            'reservas_afectadas', v_count_reservas,\r\n            'stock_mov_afectados', v_count_stock\r\n        )\r\n    );\r\n\r\nEXCEPTION WHEN OTHERS THEN\r\n    -- En caso de error, aseguramos que los triggers se vuelvan a prender para no romper el sistema\r\n    ALTER TABLE public.ventas_detalles ENABLE TRIGGER trg_auto_learning_ventas;\r\n    ALTER TABLE public.compras_detalles ENABLE TRIGGER trg_auto_learning_compras;\r\n    ALTER TABLE public.stock_movimientos ENABLE TRIGGER trg_auto_stock_movimientos;\r\n    \r\n    RETURN jsonb_build_object('success', false, 'error', SQLERRM);\r\nEND;\r\n$function$\n"
  },
  {
    "nombre_funcion": "get_productos_catalog_txt",
    "codigo_fuente": "CREATE OR REPLACE FUNCTION public.get_productos_catalog_txt(p_search text DEFAULT NULL::text)\n RETURNS text\n LANGUAGE plpgsql\n SECURITY DEFINER\nAS $function$\nDECLARE\n    v_catalogo TEXT;\nBEGIN\n    IF p_search IS NULL OR p_search = '' THEN\n        -- Si no hay búsqueda, devolvemos un resumen o nada (para no saturar)\n        SELECT string_agg(nombre || ' ($' || ultimo_precio_venta || ')', chr(10))\n        into v_catalogo\n        FROM (SELECT nombre, ultimo_precio_venta FROM public.productos_base ORDER BY nombre LIMIT 50) as sub;\n    ELSE\n        -- Si hay búsqueda, usamos la función de similitud\n        SELECT string_agg(nombre || ' ($' || precio || ')', chr(10))\n        into v_catalogo\n        FROM public.fn_buscar_productos_similares(p_search);\n    END IF;\n    \n    RETURN COALESCE(v_catalogo, 'No se encontraron productos similares.');\nEND;\n$function$\n"
  },
  {
    "nombre_funcion": "corregir_operacion_v4",
    "codigo_fuente": "CREATE OR REPLACE FUNCTION public.corregir_operacion_v4(p_input jsonb)\n RETURNS jsonb\n LANGUAGE plpgsql\nAS $function$\nDECLARE\n    -- Variables de entrada\n    v_operacion_id_raw text;\n    v_operacion_id_final text;\n    v_producto_busqueda text;\n    v_nuevo_nombre text;\n    v_nuevo_precio numeric;\n    v_nueva_cantidad int;\n\n    -- Variables internas\n    v_tipo text;\n    v_item_id bigint;\n    v_count int;\n    v_nombres_encontrados text;\n    v_total_nuevo numeric;\nBEGIN\n    -- 1. LIMPIEZA DE DATOS (Igual que antes)\n    v_operacion_id_raw := NULLIF(TRIM(p_input->>'operacion_id'), '');\n    v_producto_busqueda := NULLIF(TRIM(p_input->>'detalle_a_corregir'), '');\n    v_nuevo_nombre := NULLIF(TRIM(p_input->'nuevos_datos'->>'nombre'), '');\n    \n    BEGIN\n        v_nuevo_precio := (p_input->'nuevos_datos'->>'precio_unitario')::numeric;\n        v_nueva_cantidad := (p_input->'nuevos_datos'->>'cantidad')::int;\n    EXCEPTION WHEN OTHERS THEN\n        v_nuevo_precio := NULL; v_nueva_cantidad := NULL;\n    END;\n\n    -- 2. RESOLVER \"ULTIMA\"\n    IF v_operacion_id_raw = 'ULTIMA' THEN\n        SELECT operacion_id INTO v_operacion_id_final\n        FROM public.historial_bot WHERE estado = 'EXITO' ORDER BY log_id DESC LIMIT 1;\n        IF v_operacion_id_final IS NULL THEN RETURN jsonb_build_object('success', false, 'error', 'Historial vacío.'); END IF;\n    ELSE\n        v_operacion_id_final := v_operacion_id_raw;\n    END IF;\n\n    v_tipo := split_part(v_operacion_id_final, '_', 1);\n\n    -- 3. VALIDACIÓN DE AMBIGÜEDAD (La Parte Nueva) 🛡️\n    -- Dependiendo del tipo, contamos cuántos items coinciden\n    IF v_tipo = 'VENTA' THEN\n        SELECT COUNT(*), STRING_AGG(producto, ', ') INTO v_count, v_nombres_encontrados\n        FROM public.ventas_detalles \n        WHERE venta_id = v_operacion_id_final AND producto ILIKE '%' || v_producto_busqueda || '%';\n        \n        -- SI HAY MÁS DE UNO, PARAMOS TODO\n        IF v_count > 1 THEN\n            RETURN jsonb_build_object('success', false, 'error', '⚠️ Ambigüedad: Encontré ' || v_count || ' productos parecidos a \"' || v_producto_busqueda || '\": (' || v_nombres_encontrados || '). Por favor sé más específico.');\n        END IF;\n\n        -- Si no hay ninguno\n        IF v_count = 0 THEN\n            RETURN jsonb_build_object('success', false, 'error', 'No encontré \"' || v_producto_busqueda || '\" en la venta ' || v_operacion_id_final);\n        END IF;\n\n        -- Si hay exactamente 1, buscamos su ID\n        SELECT id INTO v_item_id FROM public.ventas_detalles \n        WHERE venta_id = v_operacion_id_final AND producto ILIKE '%' || v_producto_busqueda || '%' LIMIT 1;\n\n        -- EJECUTAMOS ACTUALIZACIÓN VENTA\n        UPDATE public.ventas_detalles\n        SET \n            producto = COALESCE(v_nuevo_nombre, producto),\n            precio_unitario = COALESCE(v_nuevo_precio, precio_unitario),\n            cantidad = COALESCE(v_nueva_cantidad, cantidad),\n            subtotal = (COALESCE(v_nueva_cantidad, cantidad) * COALESCE(v_nuevo_precio, precio_unitario))\n        WHERE id = v_item_id;\n\n        -- Recalculos Venta\n        SELECT COALESCE(SUM(subtotal),0) INTO v_total_nuevo FROM public.ventas_detalles WHERE venta_id = v_operacion_id_final;\n        UPDATE public.ventas SET total = v_total_nuevo WHERE venta_id = v_operacion_id_final;\n        UPDATE public.movimientos_dinero SET monto = v_total_nuevo WHERE referencia_id = v_operacion_id_final;\n\n    ELSIF v_tipo = 'COMPRA' THEN\n        -- Repetimos lógica de seguridad para COMPRA\n        SELECT COUNT(*), STRING_AGG(producto, ', ') INTO v_count, v_nombres_encontrados\n        FROM public.compras_detalles \n        WHERE compra_id = v_operacion_id_final AND producto ILIKE '%' || v_producto_busqueda || '%';\n\n        IF v_count > 1 THEN\n            RETURN jsonb_build_object('success', false, 'error', '⚠️ Ambigüedad: (' || v_nombres_encontrados || '). Sé más específico.');\n        END IF;\n        IF v_count = 0 THEN RETURN jsonb_build_object('success', false, 'error', 'Producto no encontrado'); END IF;\n\n        SELECT id INTO v_item_id FROM public.compras_detalles WHERE compra_id = v_operacion_id_final AND producto ILIKE '%' || v_producto_busqueda || '%' LIMIT 1;\n\n        -- Update Compra...\n        UPDATE public.compras_detalles\n        SET \n            producto = COALESCE(v_nuevo_nombre, producto),\n            precio_unitario = COALESCE(v_nuevo_precio, precio_unitario),\n            cantidad = COALESCE(v_nueva_cantidad, cantidad),\n            subtotal = (COALESCE(v_nueva_cantidad, cantidad) * COALESCE(v_nuevo_precio, precio_unitario))\n        WHERE id = v_item_id;\n\n        SELECT COALESCE(SUM(subtotal),0) INTO v_total_nuevo FROM public.compras_detalles WHERE compra_id = v_operacion_id_final;\n        UPDATE public.compras SET total = v_total_nuevo WHERE compra_id = v_operacion_id_final;\n        UPDATE public.movimientos_dinero SET monto = v_total_nuevo WHERE referencia_id = v_operacion_id_final;\n\n    -- (Puedes agregar el bloque RESERVA aquí siguiendo el mismo patrón)\n\n    ELSE\n        RETURN jsonb_build_object('success', false, 'error', 'Tipo desconocido');\n    END IF;\n\n    RETURN jsonb_build_object(\n        'success', true, \n        'mensaje', '✅ Corrección exitosa. Nuevo total: $' || v_total_nuevo\n    );\n\nEXCEPTION WHEN OTHERS THEN\n    RETURN jsonb_build_object('success', false, 'error', SQLERRM);\nEND;\n$function$\n"
  },
  {
    "nombre_funcion": "limpiar_productos_huerfanos",
    "codigo_fuente": "CREATE OR REPLACE FUNCTION public.limpiar_productos_huerfanos()\n RETURNS jsonb\n LANGUAGE plpgsql\nAS $function$\n            DECLARE\n                v_deleted_count integer;\n            BEGIN\n                -- 1. Identificar y borrar productos en productos_base que:\n                --    a) No tengan movimientos en stock_movimientos (CASE INSENSITIVE)\n                --    b) NO tengan registros en compras_detalles (SAFETY CHECK)\n                --    c) NO tengan registros en ventas_detalles (SAFETY CHECK)\n                WITH deleted AS (\n                    DELETE FROM public.productos_base pb\n                    WHERE NOT EXISTS (\n                        SELECT 1 FROM public.stock_movimientos sm\n                        WHERE UPPER(TRIM(sm.producto)) = UPPER(TRIM(pb.nombre))\n                    )\n                    AND NOT EXISTS (\n                        SELECT 1 FROM public.compras_detalles cd\n                        WHERE UPPER(TRIM(cd.producto)) = UPPER(TRIM(pb.nombre))\n                    )\n                    AND NOT EXISTS (\n                        SELECT 1 FROM public.ventas_detalles vd\n                        WHERE UPPER(TRIM(vd.producto)) = UPPER(TRIM(pb.nombre))\n                    )\n                    RETURNING *\n                )\n                SELECT count(*) INTO v_deleted_count FROM deleted;\n\n                RETURN jsonb_build_object(\n                    'success', true,\n                    'productos_eliminados', v_deleted_count,\n                    'fecha', now()\n                );\n            EXCEPTION WHEN OTHERS THEN\n                RETURN jsonb_build_object('success', false, 'error', SQLERRM);\n            END;\n            $function$\n"
  },
  {
    "nombre_funcion": "sincronizar_precios_productos",
    "codigo_fuente": "CREATE OR REPLACE FUNCTION public.sincronizar_precios_productos()\n RETURNS void\n LANGUAGE plpgsql\n SECURITY DEFINER\nAS $function$\nBEGIN\n    -- 1. Actualizar precios usando una lógica masiva (mucho más rápido que un loop)\n    -- FIX: Usamos public.normalizar_texto() para agrupar y unir correctamente\n    WITH ultimas_ventas AS (\n        -- Buscamos el precio de la VENTA más reciente para cada producto (normalizado)\n        SELECT DISTINCT ON (public.normalizar_texto(vd.producto)) \n            public.normalizar_texto(vd.producto) as nombre_norm, \n            vd.precio_unitario\n        FROM public.ventas_detalles vd\n        JOIN public.ventas v ON vd.venta_id = v.venta_id\n        WHERE vd.producto IS NOT NULL\n        ORDER BY public.normalizar_texto(vd.producto), v.fecha DESC\n    ),\n    ultimas_compras AS (\n        -- Buscamos el costo de la COMPRA más reciente para cada producto (normalizado)\n        SELECT DISTINCT ON (public.normalizar_texto(cd.producto)) \n            public.normalizar_texto(cd.producto) as nombre_norm, \n            cd.precio_unitario\n        FROM public.compras_detalles cd\n        JOIN public.compras c ON cd.compra_id = c.compra_id\n        WHERE cd.producto IS NOT NULL\n        ORDER BY public.normalizar_texto(cd.producto), c.\"Fecha\" DESC\n    )\n    UPDATE public.productos_base p\n    SET \n        -- Si hay venta nueva, actualizamos. Si no, dejamos el que estaba.\n        -- FIX: Accedemos a través del alias 'sub' de la subquerie de abajo\n        ultimo_precio_venta = COALESCE(sub.precio_venta, p.ultimo_precio_venta),\n        \n        -- Si hay compra nueva, actualizamos (casteando a numeric por si acaso)\n        ultimo_costo_compra = COALESCE(sub.precio_compra::numeric, p.ultimo_costo_compra),\n        \n        fecha_actualizacion = NOW()\n    FROM (\n        SELECT \n            COALESCE(uv.nombre_norm, uc.nombre_norm) as nombre_norm,\n            uv.precio_unitario as precio_venta,\n            uc.precio_unitario as precio_compra\n        FROM ultimas_ventas uv\n        FULL JOIN ultimas_compras uc ON uv.nombre_norm = uc.nombre_norm\n    ) sub\n    WHERE p.nombre = sub.nombre_norm;\n\nEND;\n$function$\n"
  },
  {
    "nombre_funcion": "corregir_operacion_v5",
    "codigo_fuente": "CREATE OR REPLACE FUNCTION public.corregir_operacion_v5(p_input jsonb)\n RETURNS jsonb\n LANGUAGE plpgsql\nAS $function$\nDECLARE\n    -- Variables de entrada\n    v_operacion_id_raw text;\n    v_operacion_id_final text;\n    v_producto_busqueda text;\n    v_nuevo_nombre text;\n    v_nuevo_precio numeric;\n    v_nueva_cantidad int;\n\n    -- Variables internas\n    v_tipo text;\n    v_item_id bigint;\n    v_count int;\n    v_nombres_encontrados text;\n    v_total_nuevo numeric;\nBEGIN\n    -- 1. EXTRACCIÓN Y LIMPIEZA\n    v_operacion_id_raw := NULLIF(TRIM(p_input->>'operacion_id'), '');\n    v_producto_busqueda := NULLIF(TRIM(p_input->>'detalle_a_corregir'), '');\n    v_nuevo_nombre := NULLIF(TRIM(p_input->'nuevos_datos'->>'nombre'), '');\n    \n    -- Casting seguro\n    BEGIN\n        v_nuevo_precio := (p_input->'nuevos_datos'->>'precio_unitario')::numeric;\n        v_nueva_cantidad := (p_input->'nuevos_datos'->>'cantidad')::int;\n    EXCEPTION WHEN OTHERS THEN\n        v_nuevo_precio := NULL; v_nueva_cantidad := NULL;\n    END;\n\n    -- 🚨 VALIDACIÓN TEMPRANA: Si no hay ID, abortamos mostrando qué llegó\n    IF v_operacion_id_raw IS NULL THEN\n        RETURN jsonb_build_object(\n            'success', false, \n            'error', 'El operacion_id llegó vacío (NULL). Revisa n8n.',\n            'debug_input', p_input\n        );\n    END IF;\n\n    -- 2. RESOLVER \"ULTIMA\"\n    IF v_operacion_id_raw = 'ULTIMA' THEN\n        SELECT operacion_id INTO v_operacion_id_final\n        FROM public.historial_bot WHERE estado = 'EXITO' ORDER BY log_id DESC LIMIT 1;\n        \n        IF v_operacion_id_final IS NULL THEN \n            RETURN jsonb_build_object('success', false, 'error', 'No encontré historial para \"ULTIMA\".'); \n        END IF;\n    ELSE\n        v_operacion_id_final := v_operacion_id_raw;\n    END IF;\n\n    -- 3. DETECTAR TIPO\n    v_tipo := split_part(v_operacion_id_final, '_', 1);\n\n    -- 4. LÓGICA POR TIPO (VENTA)\n    IF v_tipo = 'VENTA' THEN\n        -- Validación de producto vacío\n        IF v_producto_busqueda IS NULL THEN\n            RETURN jsonb_build_object('success', false, 'error', 'No dijiste qué producto corregir (detalle_a_corregir es NULL).');\n        END IF;\n\n        -- Detección de Ambigüedad\n        SELECT COUNT(*), STRING_AGG(producto, ', ') INTO v_count, v_nombres_encontrados\n        FROM public.ventas_detalles \n        WHERE venta_id = v_operacion_id_final AND producto ILIKE '%' || v_producto_busqueda || '%';\n        \n        IF v_count > 1 THEN\n            RETURN jsonb_build_object('success', false, 'error', '⚠️ Ambigüedad: hay ' || v_count || ' productos: (' || COALESCE(v_nombres_encontrados, '') || '). Sé más específico.');\n        END IF;\n\n        IF v_count = 0 THEN\n            RETURN jsonb_build_object('success', false, 'error', 'No encontré \"' || v_producto_busqueda || '\" en la venta ' || v_operacion_id_final);\n        END IF;\n\n        -- Obtener ID exacto\n        SELECT id INTO v_item_id FROM public.ventas_detalles \n        WHERE venta_id = v_operacion_id_final AND producto ILIKE '%' || v_producto_busqueda || '%' LIMIT 1;\n\n        -- UPDATE\n        UPDATE public.ventas_detalles\n        SET \n            producto = COALESCE(v_nuevo_nombre, producto),\n            precio_unitario = COALESCE(v_nuevo_precio, precio_unitario),\n            cantidad = COALESCE(v_nueva_cantidad, cantidad),\n            subtotal = (COALESCE(v_nueva_cantidad, cantidad) * COALESCE(v_nuevo_precio, precio_unitario))\n        WHERE id = v_item_id;\n\n        -- RECALCULO TOTALES\n        SELECT COALESCE(SUM(subtotal),0) INTO v_total_nuevo FROM public.ventas_detalles WHERE venta_id = v_operacion_id_final;\n        UPDATE public.ventas SET total = v_total_nuevo WHERE venta_id = v_operacion_id_final;\n        UPDATE public.movimientos_dinero SET monto = v_total_nuevo WHERE referencia_id = v_operacion_id_final;\n\n    -- (Aquí irían los bloques COMPRA y RESERVA igual que arriba, omitidos por brevedad pero la lógica es la misma)\n\n    ELSE\n        -- Uso COALESCE para evitar que el error sea NULL\n        RETURN jsonb_build_object('success', false, 'error', 'Tipo desconocido o ID inválido: ' || COALESCE(v_operacion_id_final, 'NULL'));\n    END IF;\n\n    RETURN jsonb_build_object(\n        'success', true, \n        'mensaje', '✅ Corrección aplicada a ' || v_operacion_id_final || '. Nuevo Total: $' || v_total_nuevo,\n        'datos_detectados', jsonb_build_object('id', v_operacion_id_final, 'producto', v_producto_busqueda)\n    );\n\nEXCEPTION WHEN OTHERS THEN\n    RETURN jsonb_build_object('success', false, 'error', 'Error SQL Crítico: ' || SQLERRM);\nEND;\n$function$\n"
  },
  {
    "nombre_funcion": "corregir_operacion_v13",
    "codigo_fuente": "CREATE OR REPLACE FUNCTION public.corregir_operacion_v13(p_input jsonb)\n RETURNS jsonb\n LANGUAGE plpgsql\nAS $function$\r\nDECLARE\r\n    v_operacion_id_raw text;\r\n    v_operacion_id_final text;\r\n    v_tipo text;\r\n    v_input_norm jsonb;\r\n    v_items_json jsonb;\r\n    v_pagos_json jsonb;\r\n    \r\n    rec_item record;\r\n    rec_pago record;\r\n    \r\n    v_monto_anterior numeric;\r\n    v_nuevo_monto numeric;\r\n    v_nuevo_metodo text;\r\n    \r\n    v_item_id bigint;\r\n    v_mov_id text;\r\n    v_cambios_items int := 0;\r\n    v_cambios_pagos int := 0;\r\n    v_total_recal numeric := 0;\r\n    v_resultado_array jsonb := '[]'::jsonb;\r\nBEGIN\r\n    -- 0. NORMALIZAR ENTRADA\r\n    v_input_norm := CASE WHEN jsonb_typeof(p_input) = 'array' THEN p_input->0 ELSE p_input END;\r\n\r\n    -- 1. IDENTIFICAR OPERACIÓN\r\n    v_operacion_id_raw := NULLIF(TRIM(v_input_norm->>'id_final'), '');\r\n    IF v_operacion_id_raw IS NULL THEN \r\n        RETURN jsonb_build_object('success', false, 'error', 'ID no especificado.');\r\n    END IF;\r\n\r\n    -- 2. RESOLVER \"ULTIMA\"\r\n    IF v_operacion_id_raw = 'ULTIMA' THEN\r\n        SELECT operacion_id INTO v_operacion_id_final FROM public.historial_bot \r\n        WHERE estado = 'EXITO' AND operacion_id IS NOT NULL ORDER BY log_id DESC LIMIT 1;\r\n    ELSE\r\n        v_operacion_id_final := v_operacion_id_raw;\r\n    END IF;\r\n\r\n    v_tipo := split_part(v_operacion_id_final, '_', 1);\r\n\r\n    -- 3. PROCESAR PRODUCTOS (Igual que v12)\r\n    -- ... [Lógica de items omitida para brevedad, se mantiene igual] ...\r\n\r\n    -- 4. PROCESAR PAGOS (ACTUALIZADO: Soporta nuevo_metodo)\r\n    v_pagos_json := v_input_norm->'pagos';\r\n    IF v_pagos_json IS NOT NULL AND jsonb_array_length(v_pagos_json) > 0 THEN\r\n        FOR rec_pago IN SELECT * FROM jsonb_array_elements(v_pagos_json) LOOP\r\n            v_monto_anterior := (rec_pago.value->>'monto_anterior')::numeric;\r\n            v_nuevo_monto := (rec_pago.value->>'nuevo_monto')::numeric;\r\n            v_nuevo_metodo := NULLIF(TRIM(rec_pago.value->>'nuevo_metodo'), '');\r\n\r\n            -- Buscamos el movimiento específico de ESTA reserva que coincida con el monto\r\n            SELECT movimiento_id INTO v_mov_id FROM public.movimientos_dinero\r\n            WHERE referencia_id = v_operacion_id_final \r\n              AND monto::numeric = v_monto_anterior \r\n            ORDER BY fecha DESC LIMIT 1;\r\n\r\n            IF v_mov_id IS NOT NULL THEN\r\n                IF v_nuevo_monto = 0 THEN\r\n                    DELETE FROM public.movimientos_dinero WHERE movimiento_id = v_mov_id;\r\n                ELSE\r\n                    UPDATE public.movimientos_dinero \r\n                    SET monto = v_nuevo_monto::text,\r\n                        metodo = COALESCE(v_nuevo_metodo, metodo) -- <--- Cambio de método\r\n                    WHERE movimiento_id = v_mov_id;\r\n                END IF;\r\n                v_cambios_pagos := v_cambios_pagos + 1;\r\n            END IF;\r\n        END LOOP;\r\n    END IF;\r\n\r\n    -- 5. RECALCULO (RESERVA usa recalcular_reserva)\r\n    IF v_tipo IN ('RESERVA', 'RES') THEN\r\n        PERFORM public.recalcular_reserva(v_operacion_id_final);\r\n    ELSIF v_tipo = 'VENTA' THEN\r\n        SELECT COALESCE(SUM(subtotal), 0) INTO v_total_recal FROM public.ventas_detalles WHERE venta_id = v_operacion_id_final;\r\n        UPDATE public.ventas SET total_venta = v_total_recal::text WHERE venta_id = v_operacion_id_final;\r\n    END IF;\r\n\r\n    -- 6. RESPUESTA (Igual que v12 con NULLIF)\r\n    -- ... [Construcción de v_resultado_array] ...\r\n\r\n    RETURN jsonb_build_object('success', true, 'mensaje', 'Corrección aplicada en ' || v_operacion_id_final, 'data', v_resultado_array);\r\nEND;\r\n$function$\n"
  },
  {
    "nombre_funcion": "auditar_y_loguear_productos",
    "codigo_fuente": "CREATE OR REPLACE FUNCTION public.auditar_y_loguear_productos()\n RETURNS void\n LANGUAGE plpgsql\nAS $function$\n    DECLARE v_result jsonb;\n    BEGIN\n      v_result := public.auditar_productos_faltantes();\n      INSERT INTO public.auditoria_productos_log (ejecutado_en, total_faltantes, detalle)\n      VALUES (\n        (v_result->>'ejecutado_en')::timestamptz,\n        (v_result->>'total_faltantes')::int,\n        v_result->'faltantes'\n      );\n    END; $function$\n"
  },
  {
    "nombre_funcion": "corregir_operacion_v12",
    "codigo_fuente": "CREATE OR REPLACE FUNCTION public.corregir_operacion_v12(p_input jsonb)\n RETURNS jsonb\n LANGUAGE plpgsql\nAS $function$\r\nDECLARE\r\n    -- Variables de Cabecera\r\n    v_operacion_id_raw text;\r\n    v_operacion_id_final text;\r\n    v_tipo text;\r\n    \r\n    -- Variables de Iteración\r\n    rec_item record;\r\n    rec_pago record;\r\n    v_input_norm jsonb;\r\n    v_items_json jsonb;\r\n    v_pagos_json jsonb;\r\n    \r\n    v_producto_busqueda text;\r\n    v_nuevo_nombre text;\r\n    v_nuevo_precio numeric;\r\n    v_nueva_cantidad numeric;\r\n    \r\n    v_monto_anterior numeric;\r\n    v_nuevo_monto numeric;\r\n    \r\n    -- Variables de Control de Cambios\r\n    v_item_id bigint;\r\n    v_mov_id text;\r\n    v_count int;\r\n    v_cambios_items int := 0;\r\n    v_cambios_pagos int := 0;\r\n    \r\n    -- Variables de Recálculo\r\n    v_total_recal numeric := 0;\r\n    \r\n    -- Variable de Resultado\r\n    v_resultado_array jsonb := '[]'::jsonb;\r\nBEGIN\r\n    -- 0. NORMALIZAR ENTRADA\r\n    IF jsonb_typeof(p_input) = 'array' THEN\r\n        v_input_norm := p_input->0;\r\n    ELSE\r\n        v_input_norm := p_input;\r\n    END IF;\r\n\r\n    -- 1. IDENTIFICAR OPERACIÓN\r\n    v_operacion_id_raw := NULLIF(TRIM(v_input_norm->>'id_final'), '');\r\n    IF v_operacion_id_raw IS NULL THEN \r\n        RETURN jsonb_build_object('success', false, 'error', 'ID de operación no especificado.');\r\n    END IF;\r\n\r\n    -- 2. RESOLVER \"ULTIMA\"\r\n    IF v_operacion_id_raw = 'ULTIMA' THEN\r\n        SELECT operacion_id INTO v_operacion_id_final\r\n        FROM public.historial_bot \r\n        WHERE estado = 'EXITO' AND operacion_id IS NOT NULL\r\n        ORDER BY log_id DESC LIMIT 1;\r\n        \r\n        IF v_operacion_id_final IS NULL THEN \r\n            RETURN jsonb_build_object('success', false, 'error', 'No hay historial para ULTIMA.');\r\n        END IF;\r\n    ELSE\r\n        v_operacion_id_final := v_operacion_id_raw;\r\n    END IF;\r\n\r\n    v_tipo := split_part(v_operacion_id_final, '_', 1);\r\n\r\n    -- 3. PROCESAR PRODUCTOS (items)\r\n    v_items_json := v_input_norm->'items';\r\n    IF v_items_json IS NOT NULL AND jsonb_array_length(v_items_json) > 0 THEN\r\n        FOR rec_item IN SELECT * FROM jsonb_array_elements(v_items_json)\r\n        LOOP\r\n            v_producto_busqueda := NULLIF(TRIM(rec_item.value->>'producto'), '');\r\n            v_nuevo_nombre      := NULLIF(TRIM(rec_item.value->>'nuevo_nombre'), '');\r\n            \r\n            BEGIN\r\n                v_nuevo_precio := (rec_item.value->>'nuevo_precio')::numeric;\r\n                v_nueva_cantidad := (rec_item.value->>'nueva_cantidad')::numeric;\r\n            EXCEPTION WHEN OTHERS THEN\r\n                v_nuevo_precio := NULL; v_nueva_cantidad := NULL;\r\n            END;\r\n\r\n            IF v_producto_busqueda IS NOT NULL THEN\r\n                -- VENTA\r\n                IF v_tipo = 'VENTA' THEN\r\n                    SELECT id INTO v_item_id FROM public.ventas_detalles \r\n                    WHERE venta_id = v_operacion_id_final AND producto ILIKE '%' || v_producto_busqueda || '%' LIMIT 1;\r\n                    IF v_item_id IS NOT NULL THEN\r\n                        UPDATE public.ventas_detalles SET \r\n                            producto = COALESCE(v_nuevo_nombre, producto),\r\n                            precio_unitario = COALESCE(v_nuevo_precio, precio_unitario),\r\n                            cantidad = COALESCE(v_nueva_cantidad::int, cantidad),\r\n                            subtotal = (COALESCE(v_nueva_cantidad::int, cantidad) * COALESCE(v_nuevo_precio, precio_unitario))\r\n                        WHERE id = v_item_id;\r\n                        v_cambios_items := v_cambios_items + 1;\r\n                    END IF;\r\n                -- COMPRA\r\n                ELSIF v_tipo = 'COMPRA' THEN\r\n                    SELECT id INTO v_item_id FROM public.compras_detalles \r\n                    WHERE compra_id = v_operacion_id_final AND producto ILIKE '%' || v_producto_busqueda || '%' LIMIT 1;\r\n                    IF v_item_id IS NOT NULL THEN\r\n                        UPDATE public.compras_detalles SET \r\n                            producto = COALESCE(v_nuevo_nombre, producto),\r\n                            precio_unitario = COALESCE(v_nuevo_precio::text, precio_unitario),\r\n                            cantidad = COALESCE(v_nueva_cantidad, cantidad),\r\n                            subtotal = (COALESCE(v_nueva_cantidad, cantidad) * COALESCE(v_nuevo_precio, precio_unitario::numeric))::text\r\n                        WHERE id = v_item_id;\r\n                        v_cambios_items := v_cambios_items + 1;\r\n                    END IF;\r\n                -- RESERVA\r\n                ELSIF v_tipo = 'RESERVA' OR v_tipo = 'RES' THEN\r\n                    SELECT id INTO v_item_id FROM public.reservas_detalles \r\n                    WHERE reserva_id = v_operacion_id_final AND producto ILIKE '%' || v_producto_busqueda || '%' LIMIT 1;\r\n                    IF v_item_id IS NOT NULL THEN\r\n                        UPDATE public.reservas_detalles SET \r\n                            producto = COALESCE(v_nuevo_nombre, producto),\r\n                            precio_unitario = COALESCE(v_nuevo_precio, precio_unitario),\r\n                            cantidad = COALESCE(v_nueva_cantidad, cantidad),\r\n                            subtotal = (COALESCE(v_nueva_cantidad, cantidad) * COALESCE(v_nuevo_precio, precio_unitario))\r\n                        WHERE id = v_item_id;\r\n                        v_cambios_items := v_cambios_items + 1;\r\n                    END IF;\r\n                END IF;\r\n            END IF;\r\n        END LOOP;\r\n    END IF;\r\n\r\n    -- 4. PROCESAR PAGOS (pagos)\r\n    v_pagos_json := v_input_norm->'pagos';\r\n    IF v_pagos_json IS NOT NULL AND jsonb_array_length(v_pagos_json) > 0 THEN\r\n        FOR rec_pago IN SELECT * FROM jsonb_array_elements(v_pagos_json)\r\n        LOOP\r\n            v_monto_anterior := (rec_pago.value->>'monto_anterior')::numeric;\r\n            v_nuevo_monto := (rec_pago.value->>'nuevo_monto')::numeric;\r\n\r\n            SELECT movimiento_id INTO v_mov_id FROM public.movimientos_dinero\r\n            WHERE referencia_id = v_operacion_id_final AND monto::numeric = v_monto_anterior ORDER BY fecha DESC LIMIT 1;\r\n\r\n            IF v_mov_id IS NOT NULL THEN\r\n                IF v_nuevo_monto = 0 THEN\r\n                    DELETE FROM public.movimientos_dinero WHERE movimiento_id = v_mov_id;\r\n                ELSE\r\n                    UPDATE public.movimientos_dinero SET monto = v_nuevo_monto::text WHERE movimiento_id = v_mov_id;\r\n                END IF;\r\n                v_cambios_pagos := v_cambios_pagos + 1;\r\n            END IF;\r\n        END LOOP;\r\n    END IF;\r\n\r\n    -- 5. RECALCULO QUIRÚRGICO\r\n    -- RESERVA: Siempre usamos recalcular_reserva porque gestiona saldos dinámicos\r\n    IF v_tipo = 'RESERVA' OR v_tipo = 'RES' THEN\r\n        IF (v_cambios_items + v_cambios_pagos) > 0 THEN\r\n            PERFORM public.recalcular_reserva(v_operacion_id_final);\r\n        END IF;\r\n    -- VENTA/COMPRA: Recalculamos total de cabecera solo si los items cambiaron\r\n    ELSIF v_tipo = 'VENTA' THEN\r\n        IF v_cambios_items > 0 THEN\r\n            SELECT COALESCE(SUM(subtotal), 0) INTO v_total_recal FROM public.ventas_detalles WHERE venta_id = v_operacion_id_final;\r\n            UPDATE public.ventas SET total_venta = v_total_recal::text WHERE venta_id = v_operacion_id_final;\r\n            -- Si cambiaron los items, ajustamos el pago principal para que coincida\r\n            UPDATE public.movimientos_dinero SET monto = v_total_recal::text \r\n            WHERE referencia_id = v_operacion_id_final AND tipo = 'ENTRADA' AND notas NOT LIKE '%Sobrante%';\r\n        END IF;\r\n    ELSIF v_tipo = 'COMPRA' THEN\r\n        IF v_cambios_items > 0 THEN\r\n            SELECT COALESCE(SUM(subtotal::numeric), 0) INTO v_total_recal FROM public.compras_detalles WHERE compra_id = v_operacion_id_final;\r\n            UPDATE public.compras SET total_compra = v_total_recal::text WHERE compra_id = v_operacion_id_final;\r\n            -- Si cambiaron los items, ajustamos el pago principal para que coincida\r\n            UPDATE public.movimientos_dinero SET monto = v_total_recal::text \r\n            WHERE referencia_id = v_operacion_id_final AND tipo = 'SALIDA';\r\n        END IF;\r\n    END IF;\r\n\r\n    -- 6. CONSTRUIR RESULTADO JSONB (ENVUELTO EN DATA PARA N8N)\r\n    RETURN jsonb_build_object(\r\n        'success', true,\r\n        'data', jsonb_build_array(\r\n            jsonb_build_object(\r\n                'tipo_op', 'CORRECCION',\r\n                'id_final', v_operacion_id_final\r\n            )\r\n        ),\r\n        'mensaje', 'Operación ' || v_operacion_id_final || ' corregida exitosamente.'\r\n    );\r\n\r\n\r\nEXCEPTION WHEN OTHERS THEN\r\n    RETURN jsonb_build_object('success', false, 'error', SQLERRM);\r\nEND;\r\n$function$\n"
  },
  {
    "nombre_funcion": "fn_cleanup_orphaned_products",
    "codigo_fuente": "CREATE OR REPLACE FUNCTION public.fn_cleanup_orphaned_products()\n RETURNS integer\n LANGUAGE plpgsql\nAS $function$\nDECLARE\n    deleted_count INTEGER;\nBEGIN\n    -- Un producto es huérfano si NO aparece en ninguna operación (ventas, compras o reservas)\n    -- Importante: Usamos public.normalizar_texto() para asegurar que coincidimos con los nombres en el catálogo\n    -- de la misma forma que lo hace la función de auditoría.\n    DELETE FROM public.productos_base \n    WHERE nombre NOT IN (\n        SELECT public.normalizar_texto(producto) FROM public.ventas_detalles WHERE producto IS NOT NULL\n        UNION\n        SELECT public.normalizar_texto(producto) FROM public.compras_detalles WHERE producto IS NOT NULL\n        UNION\n        SELECT public.normalizar_texto(producto) FROM public.reservas_detalles WHERE producto IS NOT NULL\n    );\n    \n    GET DIAGNOSTICS deleted_count = ROW_COUNT;\n    RETURN deleted_count;\nEND;\n$function$\n"
  },
  {
    "nombre_funcion": "corregir_operacion_v14",
    "codigo_fuente": "CREATE OR REPLACE FUNCTION public.corregir_operacion_v14(p_input jsonb)\n RETURNS jsonb\n LANGUAGE plpgsql\nAS $function$\r\nDECLARE\r\n    -- Variables de estructura\r\n    v_input_norm jsonb;\r\n    v_id_final text;\r\n    v_tipo text;\r\n    v_items_json jsonb; -- <--- AGREGADA\r\n    v_pagos_json jsonb; -- <--- AGREGADA (Culpable del error anterior)\r\n    \r\n    -- Cursores para loops\r\n    rec_item record;\r\n    rec_pago record;\r\n    \r\n    -- Variables para Items\r\n    v_item_id bigint;\r\n    v_old_nombre text;\r\n    v_old_cantidad numeric;\r\n    v_old_precio numeric;\r\n    \r\n    -- Variables para Pagos\r\n    v_mov_id text;\r\n    v_monto_anterior numeric;\r\n    v_nuevo_monto numeric;\r\n    v_nuevo_metodo text;\r\n    \r\n    -- Contadores y resultados\r\n    v_cambios_items int := 0;\r\n    v_cambios_pagos int := 0;\r\n    v_resultado_array jsonb := '[]'::jsonb;\r\nBEGIN\r\n    -- 0. NORMALIZACIÓN DE ENTRADA\r\n    v_input_norm := CASE WHEN jsonb_typeof(p_input) = 'array' THEN p_input->0 ELSE p_input END;\r\n\r\n    -- 1. IDENTIFICAR OPERACIÓN\r\n    v_id_final := NULLIF(TRIM(v_input_norm->>'id_final'), '');\r\n    IF v_id_final IS NULL THEN \r\n        RETURN jsonb_build_object('success', false, 'error', 'ID de operación no especificado.'); \r\n    END IF;\r\n\r\n    -- RESOLVER \"ULTIMA\"\r\n    IF v_id_final = 'ULTIMA' THEN\r\n        SELECT operacion_id INTO v_id_final FROM public.historial_bot \r\n        WHERE estado = 'EXITO' AND operacion_id IS NOT NULL ORDER BY log_id DESC LIMIT 1;\r\n        IF v_id_final IS NULL THEN RETURN jsonb_build_object('success', false, 'error', 'No hay historial para ULTIMA.'); END IF;\r\n    END IF;\r\n\r\n    v_tipo := split_part(v_id_final, '_', 1);\r\n\r\n    -- 2. PROCESAR PRODUCTOS (ITEMS)\r\n    v_items_json := v_input_norm->'items';\r\n    IF v_items_json IS NOT NULL AND jsonb_array_length(v_items_json) > 0 THEN\r\n        FOR rec_item IN SELECT * FROM jsonb_array_elements(v_items_json) LOOP\r\n            \r\n            -- Buscamos el ítem actual según la tabla\r\n            IF v_tipo IN ('RESERVA', 'RES') THEN\r\n                SELECT id, producto, cantidad, precio_unitario INTO v_item_id, v_old_nombre, v_old_cantidad, v_old_precio\r\n                FROM public.reservas_detalles \r\n                WHERE reserva_id = v_id_final AND producto ILIKE '%' || (rec_item.value->>'producto') || '%' LIMIT 1;\r\n            ELSIF v_tipo = 'VENTA' THEN\r\n                SELECT id, producto, cantidad::numeric, precio_unitario INTO v_item_id, v_old_nombre, v_old_cantidad, v_old_precio\r\n                FROM public.ventas_detalles \r\n                WHERE venta_id = v_id_final AND producto ILIKE '%' || (rec_item.value->>'producto') || '%' LIMIT 1;\r\n            END IF;\r\n\r\n            IF v_item_id IS NOT NULL THEN\r\n                DECLARE\r\n                    v_new_q numeric := COALESCE((rec_item.value->>'nueva_cantidad')::numeric, v_old_cantidad);\r\n                    v_new_p numeric := COALESCE((rec_item.value->>'nuevo_precio')::numeric, v_old_precio);\r\n                    v_new_n text    := COALESCE(NULLIF(TRIM(rec_item.value->>'nuevo_nombre'), ''), v_old_nombre);\r\n                BEGIN\r\n                    IF v_tipo IN ('RESERVA', 'RES') THEN\r\n                        UPDATE public.reservas_detalles SET \r\n                            producto = v_new_n, cantidad = v_new_q, precio_unitario = v_new_p, subtotal = (v_new_q * v_new_p)\r\n                        WHERE id = v_item_id;\r\n                    ELSE\r\n                        UPDATE public.ventas_detalles SET \r\n                            producto = v_new_n, cantidad = v_new_q::int, precio_unitario = v_new_p, subtotal = (v_new_q * v_new_p)\r\n                        WHERE id = v_item_id;\r\n                    END IF;\r\n\r\n                    -- Sincronizar Stock si el nombre cambió\r\n                    IF v_new_n != v_old_nombre THEN\r\n                        UPDATE public.stock_movimientos SET producto = v_new_n\r\n                        WHERE referencia_id = v_id_final AND producto = v_old_nombre;\r\n                    END IF;\r\n                END;\r\n                v_cambios_items := v_cambios_items + 1;\r\n            END IF;\r\n        END LOOP;\r\n    END IF;\r\n\r\n    -- 3. PROCESAR PAGOS\r\n    v_pagos_json := v_input_norm->'pagos';\r\n    IF v_pagos_json IS NOT NULL AND jsonb_array_length(v_pagos_json) > 0 THEN\r\n        FOR rec_pago IN SELECT * FROM jsonb_array_elements(v_pagos_json) LOOP\r\n            v_monto_anterior := (rec_pago.value->>'monto_anterior')::numeric;\r\n            v_nuevo_monto := (rec_pago.value->>'nuevo_monto')::numeric;\r\n            v_nuevo_metodo := NULLIF(TRIM(rec_pago.value->>'nuevo_metodo'), '');\r\n\r\n            SELECT movimiento_id INTO v_mov_id FROM public.movimientos_dinero\r\n            WHERE referencia_id = v_id_final AND monto::numeric = v_monto_anterior \r\n            ORDER BY fecha DESC LIMIT 1;\r\n\r\n            IF v_mov_id IS NOT NULL THEN\r\n                IF v_nuevo_monto = 0 THEN\r\n                    DELETE FROM public.movimientos_dinero WHERE movimiento_id = v_mov_id;\r\n                ELSE\r\n                    UPDATE public.movimientos_dinero \r\n                    SET monto = v_nuevo_monto::text, metodo = COALESCE(v_nuevo_metodo, metodo)\r\n                    WHERE movimiento_id = v_mov_id;\r\n                END IF;\r\n                v_cambios_pagos := v_cambios_pagos + 1;\r\n            END IF;\r\n        END LOOP;\r\n    END IF;\r\n\r\n    -- 4. RECALCULO FINAL\r\n    IF v_tipo IN ('RESERVA', 'RES') THEN\r\n        PERFORM public.recalcular_reserva(v_id_final);\r\n    ELSIF v_tipo = 'VENTA' THEN\r\n        UPDATE public.ventas SET total_venta = (SELECT SUM(subtotal) FROM public.ventas_detalles WHERE venta_id = v_id_final)::text WHERE venta_id = v_id_final;\r\n        UPDATE public.movimientos_dinero SET monto = (SELECT total_venta FROM public.ventas WHERE venta_id = v_id_final)\r\n        WHERE referencia_id = v_id_final AND referencia_tipo = 'VENTA';\r\n    END IF;\r\n\r\n    RETURN jsonb_build_object(\r\n        'success', true, \r\n        'mensaje', 'Corrección aplicada correctamente.',\r\n        'detalles', jsonb_build_object(\r\n            'items', v_cambios_items,\r\n            'pagos', v_cambios_pagos,\r\n            'id', v_id_final\r\n        )\r\n    );\r\nEND;\r\n$function$\n"
  },
  {
    "nombre_funcion": "corregir_operacion_v18",
    "codigo_fuente": "CREATE OR REPLACE FUNCTION public.corregir_operacion_v18(p_input jsonb)\n RETURNS jsonb\n LANGUAGE plpgsql\nAS $function$\nDECLARE\n    v_input_norm jsonb;\n    v_id_final text;\n    v_id_upper text;\n    v_tipo text;\n    v_items_json jsonb;\n    rec_item record;\n    v_item_id bigint;\n    v_old_n text; v_old_q numeric; v_old_p numeric;\n    v_new_n text; v_new_q numeric; v_new_p numeric;\n    v_reporte_detallado text := '';\n    v_total_recal numeric := 0;\n    v_cambios_realizados int := 0;\n    v_salto text := chr(10);\nBEGIN\n    v_input_norm := CASE WHEN jsonb_typeof(p_input) = 'array' THEN p_input->0 ELSE p_input END;\n    v_id_final := NULLIF(TRIM(v_input_norm->>'id_final'), '');\n    IF v_id_final IS NULL THEN RETURN jsonb_build_object('success', false, 'error', 'ID no especificado.'); END IF;\n    \n    v_id_upper := UPPER(v_id_final);\n    v_tipo := CASE \n        WHEN v_id_upper LIKE 'VE_%' THEN 'VENTA'\n        WHEN v_id_upper LIKE 'CO_%' THEN 'COMPRA'\n        WHEN v_id_upper LIKE 'RES_%' OR v_id_upper LIKE 'RE_%' THEN 'RESERVA'\n        ELSE split_part(v_id_upper, '_', 1)\n    END;\n\n    v_reporte_detallado := '🛠️ *Corrección en ' || v_id_upper || '*' || v_salto;\n    \n    v_items_json := v_input_norm->'items';\n    IF v_items_json IS NOT NULL AND jsonb_array_length(v_items_json) > 0 THEN\n        FOR rec_item IN SELECT * FROM jsonb_array_elements(v_items_json) LOOP\n            v_item_id := (rec_item.value->>'id')::bigint; -- Intentar usar ID directo\n            \n            IF v_item_id IS NOT NULL THEN\n                -- Buscar por ID (Mucho más robusto)\n                IF v_tipo = 'RESERVA' THEN\n                    SELECT producto, cantidad, precio_unitario INTO v_old_n, v_old_q, v_old_p FROM public.reservas_detalles WHERE id = v_item_id;\n                ELSIF v_tipo = 'COMPRA' THEN\n                    SELECT producto, cantidad, precio_unitario INTO v_old_n, v_old_q, v_old_p FROM public.compras_detalles WHERE id = v_item_id;\n                ELSE\n                    SELECT producto, cantidad::numeric, precio_unitario INTO v_old_n, v_old_q, v_old_p FROM public.ventas_detalles WHERE id = v_item_id;\n                END IF;\n            ELSE\n                -- Fallback a búsqueda por nombre (vía v17)\n                IF v_tipo = 'RESERVA' THEN\n                    SELECT id, producto, cantidad, precio_unitario INTO v_item_id, v_old_n, v_old_q, v_old_p\n                    FROM public.reservas_detalles WHERE UPPER(reserva_id) = v_id_upper \n                    AND (producto = TRIM(rec_item.value->>'producto') OR public.normalizar_texto(producto) = public.normalizar_texto(rec_item.value->>'producto')) LIMIT 1;\n                ELSIF v_tipo = 'COMPRA' THEN\n                    SELECT id, producto, cantidad, precio_unitario INTO v_item_id, v_old_n, v_old_q, v_old_p\n                    FROM public.compras_detalles WHERE UPPER(compra_id) = v_id_upper \n                    AND (producto = TRIM(rec_item.value->>'producto') OR public.normalizar_texto(producto) = public.normalizar_texto(rec_item.value->>'producto')) LIMIT 1;\n                ELSE \n                    SELECT id, producto, cantidad::numeric, precio_unitario INTO v_item_id, v_old_n, v_old_q, v_old_p\n                    FROM public.ventas_detalles WHERE UPPER(venta_id) = v_id_upper \n                    AND (producto = TRIM(rec_item.value->>'producto') OR public.normalizar_texto(producto) = public.normalizar_texto(rec_item.value->>'producto')) LIMIT 1;\n                END IF;\n            END IF;\n\n            IF v_item_id IS NOT NULL AND v_old_n IS NOT NULL THEN\n                v_new_n := COALESCE(NULLIF(TRIM(rec_item.value->>'nuevo_nombre'), ''), v_old_n);\n                v_new_q := COALESCE((rec_item.value->>'nueva_cantidad')::numeric, v_old_q);\n                v_new_p := COALESCE((rec_item.value->>'nuevo_precio')::numeric, v_old_p);\n\n                IF (v_new_n != v_old_n OR v_new_q != v_old_q OR v_new_p != v_old_p) THEN\n                    IF v_tipo = 'RESERVA' THEN\n                        UPDATE public.reservas_detalles SET producto = v_new_n, cantidad = v_new_q, precio_unitario = v_new_p, subtotal = (v_new_q * v_new_p) WHERE id = v_item_id;\n                    ELSIF v_tipo = 'COMPRA' THEN\n                        UPDATE public.compras_detalles SET producto = v_new_n, cantidad = v_new_q, precio_unitario = v_new_p, subtotal = (v_new_q * v_new_p) WHERE id = v_item_id;\n                    ELSE\n                        UPDATE public.ventas_detalles SET producto = v_new_n, cantidad = v_new_q::int, precio_unitario = v_new_p, subtotal = (v_new_q * v_new_p) WHERE id = v_item_id;\n                    END IF;\n                    UPDATE public.stock_movimientos SET producto = v_new_n, cantidad = v_new_q WHERE UPPER(referencia_id) = v_id_upper AND (producto = v_old_n OR public.normalizar_texto(producto) = public.normalizar_texto(v_old_n));\n                    v_cambios_realizados := v_cambios_realizados + 1;\n                END IF;\n            END IF;\n        END LOOP;\n    END IF;\n\n    IF v_tipo = 'RESERVA' THEN\n        PERFORM public.recalcular_reserva(v_id_final);\n        SELECT total_reserva INTO v_total_recal FROM public.reservas WHERE UPPER(reserva_id) = v_id_upper;\n    ELSIF v_tipo = 'COMPRA' THEN\n        SELECT COALESCE(SUM(subtotal), 0) INTO v_total_recal FROM public.compras_detalles WHERE UPPER(compra_id) = v_id_upper;\n        UPDATE public.compras SET total_compra = v_total_recal WHERE UPPER(compra_id) = v_id_upper;\n    ELSE\n        SELECT COALESCE(SUM(subtotal), 0) INTO v_total_recal FROM public.ventas_detalles WHERE UPPER(venta_id) = v_id_upper;\n        UPDATE public.ventas SET total_venta = v_total_recal WHERE UPPER(venta_id) = v_id_upper;\n    END IF;\n\n    RETURN jsonb_build_object('success', true, 'mensaje', v_reporte_detallado, 'count', v_cambios_realizados, 'id', v_id_upper);\nEND;\n$function$\n"
  },
  {
    "nombre_funcion": "fn_modificar_producto_y_cantidad_global",
    "codigo_fuente": "CREATE OR REPLACE FUNCTION public.fn_modificar_producto_y_cantidad_global(p_nombre_viejo text, p_nombre_nuevo text, p_nueva_cantidad numeric)\n RETURNS jsonb\n LANGUAGE plpgsql\nAS $function$\r\nDECLARE\r\n    v_ids_compras text[];\r\n    v_ids_ventas text[];\r\n    v_ids_reservas text[];\r\nBEGIN\r\n    -- Normalizar nombres\r\n    p_nombre_viejo := TRIM(UPPER(p_nombre_viejo));\r\n    p_nombre_nuevo := TRIM(UPPER(p_nombre_nuevo));\r\n\r\n    -- A. Actualizar COMPRAS (Detalle)\r\n    -- Guardamos las IDs afectadas para actualizar cabeceras luego\r\n    WITH updated_c AS (\r\n        UPDATE public.compras_detalles \r\n        SET producto = p_nombre_nuevo,\r\n            cantidad = p_nueva_cantidad,\r\n            subtotal = (p_nueva_cantidad * precio_unitario::numeric)::text\r\n        WHERE UPPER(producto) = p_nombre_viejo\r\n        RETURNING compra_id\r\n    ) SELECT array_agg(DISTINCT compra_id) INTO v_ids_compras FROM updated_c;\r\n\r\n    -- B. Actualizar VENTAS (Detalle)\r\n    WITH updated_v AS (\r\n        UPDATE public.ventas_detalles \r\n        SET producto = p_nombre_nuevo,\r\n            cantidad = p_nueva_cantidad::integer,\r\n            subtotal = (p_nueva_cantidad * precio_unitario)\r\n        WHERE UPPER(producto) = p_nombre_viejo\r\n        RETURNING venta_id\r\n    ) SELECT array_agg(DISTINCT venta_id) INTO v_ids_ventas FROM updated_v;\r\n\r\n    -- C. Actualizar RESERVAS (Detalle)\r\n    WITH updated_r AS (\r\n        UPDATE public.reservas_detalles \r\n        SET producto = p_nombre_nuevo,\r\n            cantidad = p_nueva_cantidad,\r\n            subtotal = (p_nueva_cantidad * precio_unitario)\r\n        WHERE UPPER(producto) = p_nombre_viejo\r\n        RETURNING reserva_id\r\n    ) SELECT array_agg(DISTINCT reserva_id) INTO v_ids_reservas FROM updated_r;\r\n\r\n    -- D. ACTUALIZAR CABECERAS (Para no romper reportes de dinero)\r\n    -- Compras\r\n    IF v_ids_compras IS NOT NULL THEN\r\n        UPDATE public.compras c\r\n        SET total_compra = (SELECT SUM(subtotal::numeric) FROM public.compras_detalles cd WHERE cd.compra_id = c.compra_id)::text\r\n        WHERE c.compra_id = ANY(v_ids_compras);\r\n    END IF;\r\n\r\n    -- Ventas\r\n    IF v_ids_ventas IS NOT NULL THEN\r\n        UPDATE public.ventas v\r\n        SET total_venta = (SELECT SUM(subtotal) FROM public.ventas_detalles vd WHERE vd.venta_id = v.venta_id)::text\r\n        WHERE v.venta_id = ANY(v_ids_ventas);\r\n        \r\n        -- Sincronizar el pago en movimientos_dinero\r\n        UPDATE public.movimientos_dinero m\r\n        SET monto = (SELECT total_venta FROM public.ventas v WHERE v.venta_id = m.referencia_id)\r\n        WHERE m.referencia_id = ANY(v_ids_ventas) AND m.referencia_tipo = 'VENTA';\r\n    END IF;\r\n\r\n    -- Reservas (Llamamos a tu función de recalculo existente)\r\n    IF v_ids_reservas IS NOT NULL THEN\r\n        DECLARE\r\n            v_rid text;\r\n        BEGIN\r\n            FOREACH v_rid IN ARRAY v_ids_reservas LOOP\r\n                PERFORM public.recalcular_reserva(v_rid);\r\n            END LOOP;\r\n        END;\r\n    END IF;\r\n\r\n    -- E. Actualizar TABLA MAESTRA\r\n    IF EXISTS (SELECT 1 FROM public.productos WHERE nombre = p_nombre_nuevo) THEN\r\n        DELETE FROM public.productos WHERE nombre = p_nombre_viejo;\r\n    ELSE\r\n        UPDATE public.productos \r\n        SET nombre = p_nombre_nuevo, fecha_actualizacion = NOW() \r\n        WHERE nombre = p_nombre_viejo;\r\n    END IF;\r\n\r\n    RETURN jsonb_build_object(\r\n        'success', true,\r\n        'mensaje', 'Limpieza global terminada. Dinero y Stock sincronizados.',\r\n        'audit', jsonb_build_object(\r\n            'compras_afectadas', COALESCE(array_length(v_ids_compras, 1), 0),\r\n            'ventas_afectadas', COALESCE(array_length(v_ids_ventas, 1), 0)\r\n        )\r\n    );\r\nEND;\r\n$function$\n"
  },
  {
    "nombre_funcion": "corregir_operacion_v15",
    "codigo_fuente": "CREATE OR REPLACE FUNCTION public.corregir_operacion_v15(p_input jsonb)\n RETURNS jsonb\n LANGUAGE plpgsql\nAS $function$\r\nDECLARE\r\n    -- Variables de estructura\r\n    v_input_norm jsonb;\r\n    v_id_final text;\r\n    v_tipo text;\r\n    v_items_json jsonb;\r\n    v_pagos_json jsonb;\r\n    \r\n    -- Cursores y variables de Items\r\n    rec_item record;\r\n    v_item_id bigint;\r\n    v_old_n text; v_old_q numeric; v_old_p numeric;\r\n    v_new_n text; v_new_q numeric; v_new_p numeric;\r\n    \r\n    -- Variables de Pagos\r\n    rec_pago record;\r\n    v_mov_id text;\r\n    v_m_ant numeric; v_m_nue numeric;\r\n    v_met_ant text; v_met_nue text;\r\n    \r\n    -- Reporte y Totales\r\n    v_reporte_detallado text := '';\r\n    v_total_recal numeric := 0;\r\n    v_cambios_realizados int := 0;\r\n    v_salto text := chr(10); -- Salto de línea\r\nBEGIN\r\n    -- 0. NORMALIZAR ENTRADA\r\n    v_input_norm := CASE WHEN jsonb_typeof(p_input) = 'array' THEN p_input->0 ELSE p_input END;\r\n\r\n    -- 1. IDENTIFICAR OPERACIÓN\r\n    v_id_final := NULLIF(TRIM(v_input_norm->>'id_final'), '');\r\n    IF v_id_final IS NULL THEN RETURN jsonb_build_object('success', false, 'error', 'ID no especificado.'); END IF;\r\n\r\n    IF v_id_final = 'ULTIMA' THEN\r\n        SELECT operacion_id INTO v_id_final FROM public.historial_bot WHERE estado = 'EXITO' AND operacion_id IS NOT NULL ORDER BY log_id DESC LIMIT 1;\r\n        IF v_id_final IS NULL THEN RETURN jsonb_build_object('success', false, 'error', 'No hay historial.'); END IF;\r\n    END IF;\r\n\r\n    v_tipo := split_part(v_id_final, '_', 1);\r\n    v_reporte_detallado := '🛠️ *Corrección en ' || v_id_final || '*' || v_salto;\r\n\r\n    -- 2. PROCESAR PRODUCTOS (ITEMS)\r\n    v_items_json := v_input_norm->'items';\r\n    IF v_items_json IS NOT NULL AND jsonb_array_length(v_items_json) > 0 THEN\r\n        FOR rec_item IN SELECT * FROM jsonb_array_elements(v_items_json) LOOP\r\n            -- Buscar data actual\r\n            IF v_tipo IN ('RESERVA', 'RES') THEN\r\n                SELECT id, producto, cantidad, precio_unitario INTO v_item_id, v_old_n, v_old_q, v_old_p\r\n                FROM public.reservas_detalles WHERE reserva_id = v_id_final AND producto ILIKE '%' || (rec_item.value->>'producto') || '%' LIMIT 1;\r\n            ELSE\r\n                SELECT id, producto, cantidad::numeric, precio_unitario INTO v_item_id, v_old_n, v_old_q, v_old_p\r\n                FROM public.ventas_detalles WHERE venta_id = v_id_final AND producto ILIKE '%' || (rec_item.value->>'producto') || '%' LIMIT 1;\r\n            END IF;\r\n\r\n            IF v_item_id IS NOT NULL THEN\r\n                v_new_n := COALESCE(NULLIF(TRIM(rec_item.value->>'nuevo_nombre'), ''), v_old_n);\r\n                v_new_q := COALESCE((rec_item.value->>'nueva_cantidad')::numeric, v_old_q);\r\n                v_new_p := COALESCE((rec_item.value->>'nuevo_precio')::numeric, v_old_p);\r\n\r\n                -- Solo reportar si realmente hay un cambio\r\n                IF (v_new_n != v_old_n OR v_new_q != v_old_q OR v_new_p != v_old_p) THEN\r\n                    v_reporte_detallado := v_reporte_detallado || v_salto || '📦 *' || v_old_n || '*:';\r\n                    IF v_new_n != v_old_n THEN v_reporte_detallado := v_reporte_detallado || v_salto || '  • Nombre: ' || v_old_n || ' ➔ ' || v_new_n; END IF;\r\n                    IF v_new_q != v_old_q THEN v_reporte_detallado := v_reporte_detallado || v_salto || '  • Cant: ' || v_old_q || ' ➔ ' || v_new_q; END IF;\r\n                    IF v_new_p != v_old_p THEN v_reporte_detallado := v_reporte_detallado || v_salto || '  • Precio: $' || v_old_p || ' ➔ $' || v_new_p; END IF;\r\n\r\n                    -- Aplicar Updates\r\n                    IF v_tipo IN ('RESERVA', 'RES') THEN\r\n                        UPDATE public.reservas_detalles SET producto = v_new_n, cantidad = v_new_q, precio_unitario = v_new_p, subtotal = (v_new_q * v_new_p) WHERE id = v_item_id;\r\n                    ELSE\r\n                        UPDATE public.ventas_detalles SET producto = v_new_n, cantidad = v_new_q::int, precio_unitario = v_new_p, subtotal = (v_new_q * v_new_p) WHERE id = v_item_id;\r\n                    END IF;\r\n\r\n                    -- Sincronizar Stock\r\n                    IF v_new_n != v_old_n THEN\r\n                        UPDATE public.stock_movimientos SET producto = v_new_n WHERE referencia_id = v_id_final AND producto = v_old_n;\r\n                    END IF;\r\n                    v_cambios_realizados := v_cambios_realizados + 1;\r\n                END IF;\r\n            END IF;\r\n        END LOOP;\r\n    END IF;\r\n\r\n    -- 3. PROCESAR PAGOS\r\n    v_pagos_json := v_input_norm->'pagos';\r\n    IF v_pagos_json IS NOT NULL AND jsonb_array_length(v_pagos_json) > 0 THEN\r\n        FOR rec_pago IN SELECT * FROM jsonb_array_elements(v_pagos_json) LOOP\r\n            v_m_ant := (rec_pago.value->>'monto_anterior')::numeric;\r\n            v_m_nue := (rec_pago.value->>'nuevo_monto')::numeric;\r\n            v_met_nue := NULLIF(TRIM(rec_pago.value->>'nuevo_metodo'), '');\r\n\r\n            SELECT movimiento_id, metodo INTO v_mov_id, v_met_ant FROM public.movimientos_dinero\r\n            WHERE referencia_id = v_id_final AND monto::numeric = v_m_ant ORDER BY fecha DESC LIMIT 1;\r\n\r\n            IF v_mov_id IS NOT NULL AND (v_m_nue != v_m_ant OR (v_met_nue IS NOT NULL AND v_met_nue != v_met_ant)) THEN\r\n                v_reporte_detallado := v_reporte_detallado || v_salto || v_salto || '💵 *Pago Corregido*:';\r\n                IF v_m_nue != v_m_ant THEN v_reporte_detallado := v_reporte_detallado || v_salto || '  • Monto: $' || v_m_ant || ' ➔ $' || v_m_nue; END IF;\r\n                IF v_met_nue IS NOT NULL AND v_met_nue != v_met_ant THEN v_reporte_detallado := v_reporte_detallado || v_salto || '  • Método: ' || v_met_ant || ' ➔ ' || v_met_nue; END IF;\r\n\r\n                IF v_m_nue = 0 THEN DELETE FROM public.movimientos_dinero WHERE movimiento_id = v_mov_id;\r\n                ELSE UPDATE public.movimientos_dinero SET monto = v_m_nue::text, metodo = COALESCE(v_met_nue, metodo) WHERE movimiento_id = v_mov_id;\r\n                END IF;\r\n                v_cambios_realizados := v_cambios_realizados + 1;\r\n            END IF;\r\n        END LOOP;\r\n    END IF;\r\n\r\n    -- 4. RECALCULO FINAL Y CIERRE DE MENSAJE\r\n    IF v_tipo IN ('RESERVA', 'RES') THEN\r\n        PERFORM public.recalcular_reserva(v_id_final);\r\n        SELECT saldo_pendiente INTO v_total_recal FROM public.reservas WHERE reserva_id = v_id_final;\r\n        v_reporte_detallado := v_reporte_detallado || v_salto || v_salto || '💰 *Nuevo Saldo Pendiente: $' || v_total_recal || '*';\r\n    ELSE\r\n        SELECT COALESCE(SUM(subtotal), 0) INTO v_total_recal FROM public.ventas_detalles WHERE venta_id = v_id_final;\r\n        UPDATE public.ventas SET total_venta = v_total_recal::text WHERE venta_id = v_id_final;\r\n        v_reporte_detallado := v_reporte_detallado || v_salto || v_salto || '💰 *Nuevo Total Operación: $' || v_total_recal || '*';\r\n    END IF;\r\n\r\n    IF v_cambios_realizados = 0 THEN\r\n        v_reporte_detallado := '⚠️ No se detectaron cambios reales para aplicar.';\r\n    END IF;\r\n\r\n    RETURN jsonb_build_object(\r\n        'success', true, \r\n        'mensaje', v_reporte_detallado,\r\n        'data', jsonb_build_array(jsonb_build_object('id_operacion', v_id_final, 'tipo_op', 'CORRECCION'))\r\n    );\r\nEND;\r\n$function$\n"
  },
  {
    "nombre_funcion": "auditar_productos_faltantes",
    "codigo_fuente": "CREATE OR REPLACE FUNCTION public.auditar_productos_faltantes()\n RETURNS jsonb\n LANGUAGE plpgsql\nAS $function$\n    DECLARE\n      v_faltantes jsonb := '[]';\n      v_total int := 0;\n    BEGIN\n      WITH ops AS (\n        SELECT 'VENTA' AS origen, vd.venta_id AS op_id,\n               vd.producto AS nom_orig, public.normalizar_texto(vd.producto) AS nom_norm\n        FROM public.ventas_detalles vd\n        UNION ALL\n        SELECT 'COMPRA', cd.compra_id, cd.producto, public.normalizar_texto(cd.producto)\n        FROM public.compras_detalles cd\n        UNION ALL\n        SELECT 'RESERVA', rd.reserva_id, rd.producto, public.normalizar_texto(rd.producto)\n        FROM public.reservas_detalles rd\n      ),\n      faltantes AS (\n        SELECT DISTINCT ops.nom_norm, ops.nom_orig, ops.origen,\n          COUNT(ops.op_id) OVER (PARTITION BY ops.nom_norm) AS total_ops\n        FROM ops\n        LEFT JOIN public.productos_base pb ON pb.nombre = ops.nom_norm\n        WHERE pb.nombre IS NULL AND ops.nom_norm IS NOT NULL AND ops.nom_norm <> ''\n        ORDER BY total_ops DESC, ops.nom_norm\n      )\n      SELECT jsonb_agg(jsonb_build_object(\n        'nombre_norm', nom_norm, 'ejemplo', nom_orig,\n        'origen', origen, 'total_ops', total_ops\n      )), COUNT(*) INTO v_faltantes, v_total FROM faltantes;\n      RETURN jsonb_build_object(\n        'ejecutado_en', NOW(),\n        'total_faltantes', COALESCE(v_total, 0),\n        'faltantes', COALESCE(v_faltantes, '[]'::jsonb)\n      );\n    END; $function$\n"
  },
  {
    "nombre_funcion": "corregir_operacion_universal",
    "codigo_fuente": "CREATE OR REPLACE FUNCTION public.corregir_operacion_universal(p_operacion_id text, p_producto_busqueda text, p_nuevo_nombre text, p_nuevo_precio numeric, p_nueva_cantidad integer)\n RETURNS jsonb\n LANGUAGE plpgsql\nAS $function$\nDECLARE\n    v_tipo text;\n    v_item_id bigint;\n    v_nuevo_subtotal numeric;\n    v_total_operacion_nuevo numeric;\nBEGIN\n    -- 1. Detectar el tipo de operación según el prefijo del ID\n    v_tipo := split_part(p_operacion_id, '_', 1); -- \"VENTA\", \"COMPRA\", \"RESERVA\"\n\n    -----------------------------------------------------\n    -- BLOQUE A: CORREGIR UNA VENTA\n    -----------------------------------------------------\n    IF v_tipo = 'VENTA' THEN\n        -- A1. Buscar el ítem\n        SELECT id INTO v_item_id FROM public.ventas_detalles \n        WHERE venta_id = p_operacion_id AND producto ILIKE '%' || p_producto_busqueda || '%' LIMIT 1;\n\n        IF v_item_id IS NULL THEN RETURN jsonb_build_object('success', false, 'error', 'Producto no encontrado en Venta'); END IF;\n\n        -- A2. Actualizar detalle\n        UPDATE public.ventas_detalles\n        SET \n            producto = COALESCE(p_nuevo_nombre, producto),\n            precio_unitario = COALESCE(p_nuevo_precio, precio_unitario),\n            cantidad = COALESCE(p_nueva_cantidad, cantidad),\n            subtotal = (COALESCE(p_nueva_cantidad, cantidad) * COALESCE(p_nuevo_precio, precio_unitario))\n        WHERE id = v_item_id;\n\n        -- A3. Recalcular Total Venta\n        SELECT COALESCE(SUM(subtotal),0) INTO v_total_operacion_nuevo FROM public.ventas_detalles WHERE venta_id = p_operacion_id;\n        UPDATE public.ventas SET total = v_total_operacion_nuevo WHERE venta_id = p_operacion_id;\n\n        -- A4. Sincronizar Caja (Movimientos Dinero)\n        UPDATE public.movimientos_dinero SET monto = v_total_operacion_nuevo WHERE referencia_id = p_operacion_id;\n\n    -----------------------------------------------------\n    -- BLOQUE B: CORREGIR UNA COMPRA\n    -----------------------------------------------------\n    ELSIF v_tipo = 'COMPRA' THEN\n        -- B1. Buscar el ítem\n        SELECT id INTO v_item_id FROM public.compras_detalles \n        WHERE compra_id = p_operacion_id AND producto ILIKE '%' || p_producto_busqueda || '%' LIMIT 1;\n\n        IF v_item_id IS NULL THEN RETURN jsonb_build_object('success', false, 'error', 'Producto no encontrado en Compra'); END IF;\n\n        -- B2. Actualizar detalle\n        UPDATE public.compras_detalles\n        SET \n            producto = COALESCE(p_nuevo_nombre, producto),\n            precio_unitario = COALESCE(p_nuevo_precio, precio_unitario),\n            cantidad = COALESCE(p_nueva_cantidad, cantidad),\n            subtotal = (COALESCE(p_nueva_cantidad, cantidad) * COALESCE(p_nuevo_precio, precio_unitario))\n        WHERE id = v_item_id;\n\n        -- B3. Recalcular Total Compra\n        SELECT COALESCE(SUM(subtotal),0) INTO v_total_operacion_nuevo FROM public.compras_detalles WHERE compra_id = p_operacion_id;\n        UPDATE public.compras SET total = v_total_operacion_nuevo WHERE compra_id = p_operacion_id;\n\n        -- B4. Sincronizar Caja\n        UPDATE public.movimientos_dinero SET monto = v_total_operacion_nuevo WHERE referencia_id = p_operacion_id;\n\n    -----------------------------------------------------\n    -- BLOQUE C: CORREGIR UNA RESERVA\n    -----------------------------------------------------\n    ELSIF v_tipo = 'RESERVA' THEN\n        -- C1. Buscar el ítem\n        SELECT id INTO v_item_id FROM public.reservas_detalles \n        WHERE reserva_id = p_operacion_id AND producto ILIKE '%' || p_producto_busqueda || '%' LIMIT 1;\n\n        IF v_item_id IS NULL THEN RETURN jsonb_build_object('success', false, 'error', 'Producto no encontrado en Reserva'); END IF;\n\n        -- C2. Actualizar detalle\n        UPDATE public.reservas_detalles\n        SET \n            producto = COALESCE(p_nuevo_nombre, producto),\n            precio_unitario = COALESCE(p_nuevo_precio, precio_unitario),\n            cantidad = COALESCE(p_nueva_cantidad, cantidad),\n            subtotal = (COALESCE(p_nueva_cantidad, cantidad) * COALESCE(p_nuevo_precio, precio_unitario))\n        WHERE id = v_item_id;\n\n        -- C3. Recalcular Total Reserva\n        SELECT COALESCE(SUM(subtotal),0) INTO v_total_operacion_nuevo FROM public.reservas_detalles WHERE reserva_id = p_operacion_id;\n        UPDATE public.reservas SET total = v_total_operacion_nuevo WHERE reserva_id = p_operacion_id;\n\n        -- NOTA IMPORTANTE PARA RESERVAS:\n        -- No actualizamos movimientos_dinero automáticamente porque las reservas pueden tener señas parciales.\n        -- Cambiar el precio total del pedido no significa que el cliente haya pagado más en ese instante.\n\n    ELSE\n        RETURN jsonb_build_object('success', false, 'error', 'Tipo de operación no soportado: ' || v_tipo);\n    END IF;\n\n    -----------------------------------------------------\n    -- RETORNO FINAL\n    -----------------------------------------------------\n    RETURN jsonb_build_object(\n        'success', true, \n        'mensaje', 'Corrección realizada en ' || v_tipo || '. Nuevo total: $' || v_total_operacion_nuevo,\n        'nuevo_total', v_total_operacion_nuevo\n    );\n\nEXCEPTION WHEN OTHERS THEN\n    RETURN jsonb_build_object('success', false, 'error', SQLERRM);\nEND;\n$function$\n"
  }
]

