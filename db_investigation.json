    "nombre_funcion": "fn_productos_view_delete",
    "codigo_fuente": "CREATE OR REPLACE FUNCTION public.fn_productos_view_delete()\n RETURNS trigger\n LANGUAGE plpgsql\nAS $function$ BEGIN DELETE FROM public.productos_base WHERE producto_id = OLD.producto_id; RETURN OLD; END; $function$\n"
