  {
    "nombre_funcion": "corregir_operacion_v9",
    "codigo_fuente": "CREATE OR REPLACE FUNCTION public.corregir_operacion_v9(p_input jsonb)\n RETURNS jsonb\n LANGUAGE plpgsql\nAS $function$\nDECLARE\n    -- Variables de entrada\n    v_operacion_id_raw text;\n    v_operacion_id_final text;\n    v_producto_busqueda text;\n    v_nuevo_nombre text;\n    v_nuevo_precio numeric;\n    v_nueva_cantidad int;\n\n    -- Variables internas\n    v_tipo text;\n    v_item_id bigint;\n    v_count int;\n    v_nombres_encontrados text;\n    v_total_nuevo numeric;\nBEGIN\n    -- 1. EXTRACCIÓN\n    v_operacion_id_raw := NULLIF(TRIM(p_input->>'id_final'), '');\n    v_producto_busqueda := NULLIF(TRIM(p_input->>'producto'), '');\n    v_nuevo_nombre := NULLIF(TRIM(p_input->>'nuevo_nombre'), '');\n    \n    BEGIN\n        v_nuevo_precio := (p_input->>'nuevo_precio')::numeric;\n        v_nueva_cantidad := (p_input->>'nueva_cantidad')::int;\n    EXCEPTION WHEN OTHERS THEN\n        v_nuevo_precio := NULL; v_nueva_cantidad := NULL;\n    END;\n\n    IF v_operacion_id_raw IS NULL THEN RETURN jsonb_build_object('success', false, 'error', 'ID nulo.'); END IF;\n\n    -- 2. RESOLVER \"ULTIMA\"\n    IF v_operacion_id_raw = 'ULTIMA' THEN\n        SELECT operacion_id INTO v_operacion_id_final\n        FROM public.historial_bot WHERE estado = 'EXITO' ORDER BY log_id DESC LIMIT 1;\n        IF v_operacion_id_final IS NULL THEN RETURN jsonb_build_object('success', false, 'error', 'Historial vacío.'); END IF;\n    ELSE\n        v_operacion_id_final := v_operacion_id_raw;\n    END IF;\n\n    -- 3. DETECTAR TIPO\n    v_tipo := split_part(v_operacion_id_final, '_', 1);\n\n    -- 4. LÓGICA VENTA\n    IF v_tipo = 'VENTA' THEN\n        IF v_producto_busqueda IS NULL THEN RETURN jsonb_build_object('success', false, 'error', 'Campo producto vacío.'); END IF;\n\n        -- Validaciones\n        SELECT COUNT(*), STRING_AGG(producto, ', ') INTO v_count, v_nombres_encontrados\n        FROM public.ventas_detalles WHERE venta_id = v_operacion_id_final AND producto ILIKE '%' || v_producto_busqueda || '%';\n        \n        IF v_count > 1 THEN RETURN jsonb_build_object('success', false, 'error', '⚠️ Ambigüedad: (' || COALESCE(v_nombres_encontrados, '') || ').'); END IF;\n        IF v_count = 0 THEN RETURN jsonb_build_object('success', false, 'error', 'No encontré \"' || v_producto_busqueda || '\"'); END IF;\n\n        SELECT id INTO v_item_id FROM public.ventas_detalles WHERE venta_id = v_operacion_id_final AND producto ILIKE '%' || v_producto_busqueda || '%' LIMIT 1;\n\n        -- Update Detalle\n        UPDATE public.ventas_detalles\n        SET \n            producto = COALESCE(v_nuevo_nombre, producto),\n            precio_unitario = COALESCE(v_nuevo_precio, precio_unitario::numeric),\n            cantidad = COALESCE(v_nueva_cantidad, cantidad::int),\n            subtotal = (COALESCE(v_nueva_cantidad, cantidad::int) * COALESCE(v_nuevo_precio, precio_unitario::numeric))\n        WHERE id = v_item_id;\n\n        -- Recalcular Total\n        SELECT COALESCE(SUM(subtotal::numeric),0) INTO v_total_nuevo FROM public.ventas_detalles WHERE venta_id = v_operacion_id_final;\n        \n        -- === CORRECCIÓN APLICADA AQUÍ ===\n        -- Usamos 'total_venta' y lo guardamos como TEXTO porque así es tu tabla\n        UPDATE public.ventas SET total_venta = v_total_nuevo::text WHERE venta_id = v_operacion_id_final;\n        \n        -- Actualizar Caja (asumiendo que 'monto' en movimientos_dinero es texto también)\n        UPDATE public.movimientos_dinero SET monto = v_total_nuevo::text WHERE referencia_id = v_operacion_id_final;\n\n    -- 5. LÓGICA COMPRA (Ya que estamos, la dejamos lista)\n    ELSIF v_tipo = 'COMPRA' THEN\n        -- ... (misma lógica de validación) ...\n        SELECT id INTO v_item_id FROM public.compras_detalles WHERE compra_id = v_operacion_id_final AND producto ILIKE '%' || v_producto_busqueda || '%' LIMIT 1;\n        \n        -- Si no encuentra, error... (omitido por brevedad, asumimos validación igual a venta)\n        \n        UPDATE public.compras_detalles\n        SET \n            producto = COALESCE(v_nuevo_nombre, producto),\n            precio_unitario = COALESCE(v_nuevo_precio::text, precio_unitario), -- Ojo, en tu esquema precio_unitario es text en compras\n            cantidad = COALESCE(v_nueva_cantidad, cantidad),\n            subtotal = (COALESCE(v_nueva_cantidad, cantidad) * COALESCE(v_nuevo_precio, precio_unitario::numeric))::text\n        WHERE id = v_item_id;\n\n        SELECT COALESCE(SUM(subtotal::numeric),0) INTO v_total_nuevo FROM public.compras_detalles WHERE compra_id = v_operacion_id_final;\n        \n        -- Usamos 'total_compra'\n        UPDATE public.compras SET total_compra = v_total_nuevo::text WHERE compra_id = v_operacion_id_final;\n        UPDATE public.movimientos_dinero SET monto = v_total_nuevo::text WHERE referencia_id = v_operacion_id_final;\n\n    ELSE\n        RETURN jsonb_build_object('success', false, 'error', 'Tipo desconocido: ' || v_operacion_id_final);\n    END IF;\n\n    RETURN jsonb_build_object(\n        'success', true, \n        'mensaje', '✅ Corrección aplicada a ' || v_operacion_id_final || '. Nuevo Total: $' || v_total_nuevo\n    );\n\nEXCEPTION WHEN OTHERS THEN\n    RETURN jsonb_build_object('success', false, 'error', 'Error SQL v9: ' || SQLERRM);\nEND;\n$function$\n"
  },
