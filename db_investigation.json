  {
    "nombre_funcion": "corregir_operacion_v6",
    "codigo_fuente": "CREATE OR REPLACE FUNCTION public.corregir_operacion_v6(p_input jsonb)\n RETURNS jsonb\n LANGUAGE plpgsql\nAS $function$\nDECLARE\n    -- Variables de entrada\n    v_operacion_id_raw text;\n    v_operacion_id_final text;\n    v_producto_busqueda text;\n    v_nuevo_nombre text;\n    v_nuevo_precio numeric;\n    v_nueva_cantidad int;\n\n    -- Variables internas\n    v_tipo text;\n    v_item_id bigint;\n    v_count int;\n    v_nombres_encontrados text;\n    v_total_nuevo numeric;\nBEGIN\n    -- 1. EXTRACCIÓN (ADAPTADA A TU JSON DE N8N)\n    -- Aquí corregimos el error de nombres:\n    v_operacion_id_raw := NULLIF(TRIM(p_input->>'id_final'), '');      -- Antes buscaba 'operacion_id'\n    v_producto_busqueda := NULLIF(TRIM(p_input->>'producto'), '');     -- Antes buscaba 'detalle_a_corregir'\n    v_nuevo_nombre := NULLIF(TRIM(p_input->>'nuevo_nombre'), '');\n    \n    -- Casting seguro (leemos directo del nivel raíz del JSON)\n    BEGIN\n        v_nuevo_precio := (p_input->>'nuevo_precio')::numeric;\n        v_nueva_cantidad := (p_input->>'nueva_cantidad')::int;\n    EXCEPTION WHEN OTHERS THEN\n        v_nuevo_precio := NULL; v_nueva_cantidad := NULL;\n    END;\n\n    -- 🚨 VALIDACIÓN TEMPRANA\n    IF v_operacion_id_raw IS NULL THEN\n        RETURN jsonb_build_object(\n            'success', false, \n            'error', 'El id_final llegó vacío (NULL).',\n            'debug_input', p_input\n        );\n    END IF;\n\n    -- 2. RESOLVER \"ULTIMA\"\n    IF v_operacion_id_raw = 'ULTIMA' THEN\n        SELECT operacion_id INTO v_operacion_id_final\n        FROM public.historial_bot WHERE estado = 'EXITO' ORDER BY log_id DESC LIMIT 1;\n        \n        IF v_operacion_id_final IS NULL THEN \n            RETURN jsonb_build_object('success', false, 'error', 'No encontré historial para \"ULTIMA\".'); \n        END IF;\n    ELSE\n        v_operacion_id_final := v_operacion_id_raw;\n    END IF;\n\n    -- 3. DETECTAR TIPO\n    v_tipo := split_part(v_operacion_id_final, '_', 1);\n\n    -- 4. LÓGICA VENTA\n    IF v_tipo = 'VENTA' THEN\n        IF v_producto_busqueda IS NULL THEN\n            RETURN jsonb_build_object('success', false, 'error', 'El campo \"producto\" vino vacío.');\n        END IF;\n\n        -- Buscar coincidencias\n        SELECT COUNT(*), STRING_AGG(producto, ', ') INTO v_count, v_nombres_encontrados\n        FROM public.ventas_detalles \n        WHERE venta_id = v_operacion_id_final AND producto ILIKE '%' || v_producto_busqueda || '%';\n        \n        IF v_count > 1 THEN\n            RETURN jsonb_build_object('success', false, 'error', '⚠️ Ambigüedad: hay ' || v_count || ' productos: (' || COALESCE(v_nombres_encontrados, '') || '). Sé más específico.');\n        END IF;\n\n        IF v_count = 0 THEN\n            RETURN jsonb_build_object('success', false, 'error', 'No encontré \"' || v_producto_busqueda || '\" en la venta ' || v_operacion_id_final);\n        END IF;\n\n        -- Obtener ID\n        SELECT id INTO v_item_id FROM public.ventas_detalles \n        WHERE venta_id = v_operacion_id_final AND producto ILIKE '%' || v_producto_busqueda || '%' LIMIT 1;\n\n        -- UPDATE\n        UPDATE public.ventas_detalles\n        SET \n            producto = COALESCE(v_nuevo_nombre, producto),\n            precio_unitario = COALESCE(v_nuevo_precio, precio_unitario),\n            cantidad = COALESCE(v_nueva_cantidad, cantidad),\n            subtotal = (COALESCE(v_nueva_cantidad, cantidad) * COALESCE(v_nuevo_precio, precio_unitario))\n        WHERE id = v_item_id;\n\n        -- RECALCULAR\n        SELECT COALESCE(SUM(subtotal),0) INTO v_total_nuevo FROM public.ventas_detalles WHERE venta_id = v_operacion_id_final;\n        UPDATE public.ventas SET total = v_total_nuevo WHERE venta_id = v_operacion_id_final;\n        UPDATE public.movimientos_dinero SET monto = v_total_nuevo WHERE referencia_id = v_operacion_id_final;\n\n    -- (Si necesitas COMPRAS o RESERVAS, avísame y te paso el bloque completo, por ahora priorizo que funcione la VENTA)\n    \n    ELSE\n        RETURN jsonb_build_object('success', false, 'error', 'Tipo desconocido o ID inválido: ' || COALESCE(v_operacion_id_final, 'NULL'));\n    END IF;\n\n    RETURN jsonb_build_object(\n        'success', true, \n        'mensaje', '✅ Corrección aplicada a ' || v_operacion_id_final || '. Nuevo Total: $' || v_total_nuevo,\n        'datos_usados', jsonb_build_object('id', v_operacion_id_final, 'producto', v_producto_busqueda, 'precio_nuevo', v_nuevo_precio)\n    );\n\nEXCEPTION WHEN OTHERS THEN\n    RETURN jsonb_build_object('success', false, 'error', 'Error SQL Crítico: ' || SQLERRM);\nEND;\n$function$\n"
  },
  {
    "nombre_funcion": "corregir_operacion_v11",
    "codigo_fuente": "CREATE OR REPLACE FUNCTION public.corregir_operacion_v11(p_input jsonb)\n RETURNS jsonb\n LANGUAGE plpgsql\nAS $function$\nDECLARE\n    -- Variables de Cabecera\n    v_operacion_id_raw text;\n    v_operacion_id_final text;\n    v_tipo text;\n    \n    -- Variables de Iteración\n    rec_item record;\n    v_items_json jsonb; -- <--- NUEVA VARIABLE PARA NORMALIZAR ENTRADA\n    v_producto_busqueda text;\n    v_nuevo_nombre text;\n    v_nuevo_precio numeric;\n    v_nueva_cantidad numeric;\n    \n    -- Variables de Auditoría (Valores viejos)\n    v_old_cantidad numeric;\n    v_old_precio numeric;\n    v_old_nombre text;\n    v_item_id bigint;\n    \n    -- Variables de Reporte\n    v_total_recalculado numeric := 0;\n    v_cambios_realizados int := 0;\n    v_reporte_detallado text := ''; \n    v_log_errores text := '';\nBEGIN\n    -- 1. IDENTIFICAR OPERACIÓN\n    v_operacion_id_raw := NULLIF(TRIM(p_input->>'id_final'), '');\n\n    IF v_operacion_id_raw IS NULL THEN \n        RETURN jsonb_build_object('success', false, 'error', 'ID de operación no especificado.'); \n    END IF;\n\n    -- 2. RESOLVER \"ULTIMA\"\n    IF v_operacion_id_raw = 'ULTIMA' THEN\n        SELECT operacion_id INTO v_operacion_id_final\n        FROM public.historial_bot \n        WHERE estado = 'EXITO' AND operacion_id IS NOT NULL\n        ORDER BY log_id DESC LIMIT 1;\n        \n        IF v_operacion_id_final IS NULL THEN \n            RETURN jsonb_build_object('success', false, 'error', 'Historial vacío.'); \n        END IF;\n    ELSE\n        v_operacion_id_final := v_operacion_id_raw;\n    END IF;\n\n    v_tipo := split_part(v_operacion_id_final, '_', 1);\n\n    -- 3. ITERAR SOBRE LOS ÍTEMS A CORREGIR\n    -- =========================================================\n    -- LÓGICA HÍBRIDA: Soporta {items: []} y objeto plano {}\n    -- =========================================================\n    IF p_input ? 'items' THEN\n        v_items_json := p_input->'items';\n    ELSE\n        -- Si no hay array \"items\", asumimos que el input es el ítem único\n        v_items_json := jsonb_build_array(p_input);\n    END IF;\n\n    FOR rec_item IN SELECT * FROM jsonb_array_elements(v_items_json)\n    LOOP\n        v_producto_busqueda := NULLIF(TRIM(rec_item.value->>'producto'), '');\n        v_nuevo_nombre      := NULLIF(TRIM(rec_item.value->>'nuevo_nombre'), '');\n        \n        BEGIN\n            v_nuevo_precio := (rec_item.value->>'nuevo_precio')::numeric;\n            v_nueva_cantidad := (rec_item.value->>'nueva_cantidad')::numeric;\n        EXCEPTION WHEN OTHERS THEN\n            v_nuevo_precio := NULL; v_nueva_cantidad := NULL;\n        END;\n\n        IF v_producto_busqueda IS NOT NULL THEN\n            \n            -- LÓGICA VENTA\n            IF v_tipo = 'VENTA' THEN\n                -- A. Buscar Datos Viejos\n                SELECT id, cantidad, precio_unitario, producto \n                INTO v_item_id, v_old_cantidad, v_old_precio, v_old_nombre\n                FROM public.ventas_detalles \n                WHERE venta_id = v_operacion_id_final \n                  AND (producto ILIKE v_producto_busqueda OR producto ILIKE '%' || v_producto_busqueda || '%')\n                ORDER BY length(producto) ASC LIMIT 1;\n\n                IF v_item_id IS NOT NULL THEN\n                    -- B. Construir Reporte de Cambios\n                    v_reporte_detallado := v_reporte_detallado || E'\\n📝 *' || v_old_nombre || '*:';\n                    \n                    IF v_nuevo_nombre IS NOT NULL AND v_nuevo_nombre != v_old_nombre THEN\n                        v_reporte_detallado := v_reporte_detallado || ' Nombre cambiado a \"' || v_nuevo_nombre || '\".';\n                    END IF;\n                    \n                    IF v_nueva_cantidad IS NOT NULL AND v_nueva_cantidad != v_old_cantidad THEN\n                        v_reporte_detallado := v_reporte_detallado || ' Cant: ' || v_old_cantidad || ' -> ' || v_nueva_cantidad || '.';\n                    END IF;\n                    \n                    IF v_nuevo_precio IS NOT NULL AND v_nuevo_precio != v_old_precio THEN\n                        v_reporte_detallado := v_reporte_detallado || ' Precio: $' || v_old_precio || ' -> $' || v_nuevo_precio || '.';\n                    END IF;\n\n                    -- C. Actualizar\n                    UPDATE public.ventas_detalles\n                    SET \n                        producto = COALESCE(v_nuevo_nombre, producto),\n                        precio_unitario = COALESCE(v_nuevo_precio, precio_unitario),\n                        cantidad = COALESCE(v_nueva_cantidad::int, cantidad),\n                        subtotal = (COALESCE(v_nueva_cantidad::int, cantidad) * COALESCE(v_nuevo_precio, precio_unitario))\n                    WHERE id = v_item_id;\n                    v_cambios_realizados := v_cambios_realizados + 1;\n                ELSE\n                    v_log_errores := v_log_errores || ' ❌ No encontré \"' || v_producto_busqueda || '\".';\n                END IF;\n\n            -- LÓGICA COMPRA\n            ELSIF v_tipo = 'COMPRA' THEN\n                SELECT id, cantidad, precio_unitario::numeric, producto \n                INTO v_item_id, v_old_cantidad, v_old_precio, v_old_nombre\n                FROM public.compras_detalles \n                WHERE compra_id = v_operacion_id_final \n                  AND (producto ILIKE v_producto_busqueda OR producto ILIKE '%' || v_producto_busqueda || '%')\n                ORDER BY length(producto) ASC LIMIT 1;\n\n                IF v_item_id IS NOT NULL THEN\n                    -- Construir Reporte Compra\n                    v_reporte_detallado := v_reporte_detallado || E'\\n📝 *' || v_old_nombre || '*:';\n                    \n                    IF v_nuevo_nombre IS NOT NULL AND v_nuevo_nombre != v_old_nombre THEN\n                        v_reporte_detallado := v_reporte_detallado || ' Nombre cambiado a \"' || v_nuevo_nombre || '\".';\n                    END IF;\n                    \n                    IF v_nueva_cantidad IS NOT NULL AND v_nueva_cantidad != v_old_cantidad THEN\n                        v_reporte_detallado := v_reporte_detallado || ' Cant: ' || v_old_cantidad || ' -> ' || v_nueva_cantidad || '.';\n                    END IF;\n                    \n                    IF v_nuevo_precio IS NOT NULL AND v_nuevo_precio != v_old_precio THEN\n                        v_reporte_detallado := v_reporte_detallado || ' Costo: $' || v_old_precio || ' -> $' || v_nuevo_precio || '.';\n                    END IF;\n\n                    UPDATE public.compras_detalles\n                    SET \n                        producto = COALESCE(v_nuevo_nombre, producto),\n                        precio_unitario = COALESCE(v_nuevo_precio::text, precio_unitario),\n                        cantidad = COALESCE(v_nueva_cantidad, cantidad),\n                        subtotal = (COALESCE(v_nueva_cantidad, cantidad) * COALESCE(v_nuevo_precio, precio_unitario::numeric))::text\n                    WHERE id = v_item_id;\n                    v_cambios_realizados := v_cambios_realizados + 1;\n                ELSE\n                    v_log_errores := v_log_errores || ' ❌ No encontré \"' || v_producto_busqueda || '\".';\n                END IF;\n            END IF;\n        END IF;\n    END LOOP;\n\n    -- 4. RECALCULO FINAL\n    IF v_cambios_realizados > 0 THEN\n        IF v_tipo = 'VENTA' THEN\n            SELECT COALESCE(SUM(subtotal), 0) INTO v_total_recalculado \n            FROM public.ventas_detalles WHERE venta_id = v_operacion_id_final;\n\n            UPDATE public.ventas SET total_venta = v_total_recalculado::text WHERE venta_id = v_operacion_id_final;\n            UPDATE public.movimientos_dinero SET monto = v_total_recalculado::text WHERE referencia_id = v_operacion_id_final AND tipo = 'ENTRADA';\n\n        ELSIF v_tipo = 'COMPRA' THEN\n            SELECT COALESCE(SUM(subtotal::numeric), 0) INTO v_total_recalculado \n            FROM public.compras_detalles WHERE compra_id = v_operacion_id_final;\n\n            UPDATE public.compras SET total_compra = v_total_recalculado::text WHERE compra_id = v_operacion_id_final;\n            UPDATE public.movimientos_dinero SET monto = v_total_recalculado::text WHERE referencia_id = v_operacion_id_final AND tipo = 'SALIDA';\n        END IF;\n\n        -- RETORNO FINAL CON EL REPORTE DETALLADO\n        RETURN jsonb_build_object(\n            'success', true, \n            'mensaje', '✅ Corrección aplicada.' || v_reporte_detallado || E'\\n\\n💰 *Nuevo Total: $' || v_total_recalculado || '*' || v_log_errores\n        );\n    ELSE\n        RETURN jsonb_build_object(\n            'success', false, \n            'error', 'No se realizaron cambios. ' || v_log_errores\n        );\n    END IF;\n\nEXCEPTION WHEN OTHERS THEN\n    RETURN jsonb_build_object('success', false, 'error', 'Error SQL v11: ' || SQLERRM);\nEND;\n$function$\n"
  },
  {
    "nombre_funcion": "corregir_operacion_v10",
    "codigo_fuente": "CREATE OR REPLACE FUNCTION public.corregir_operacion_v10(p_input jsonb)\n RETURNS jsonb\n LANGUAGE plpgsql\nAS $function$\r\nDECLARE\r\n    -- Variables de Cabecera\r\n    v_operacion_id_raw text;\r\n    v_operacion_id_final text;\r\n    v_tipo text;\r\n    \r\n    -- Variables de Iteración\r\n    rec_item record;\r\n    v_producto_busqueda text;\r\n    v_nuevo_nombre text;\r\n    v_nuevo_precio numeric;\r\n    v_nueva_cantidad numeric;\r\n    \r\n    -- Variables Internas\r\n    v_item_id bigint;\r\n    v_count int;\r\n    v_total_recalculado numeric := 0;\r\n    v_cambios_realizados int := 0;\r\n    v_log_errores text := '';\r\nBEGIN\r\n    -- 1. IDENTIFICAR OPERACIÓN\r\n    v_operacion_id_raw := NULLIF(TRIM(p_input->>'id_final'), '');\r\n\r\n    IF v_operacion_id_raw IS NULL THEN \r\n        RETURN jsonb_build_object('success', false, 'error', 'ID de operación no especificado.'); \r\n    END IF;\r\n\r\n    -- 2. RESOLVER \"ULTIMA\" O ID DIRECTO\r\n    IF v_operacion_id_raw = 'ULTIMA' THEN\r\n        -- Buscamos en el historial del bot la última operación exitosa\r\n        -- Ojo: Ajustar si tu lógica de historial es diferente\r\n        SELECT operacion_id INTO v_operacion_id_final\r\n        FROM public.historial_bot \r\n        WHERE estado = 'EXITO' \r\n          AND operacion_id IS NOT NULL\r\n        ORDER BY log_id DESC \r\n        LIMIT 1;\r\n        \r\n        IF v_operacion_id_final IS NULL THEN \r\n            RETURN jsonb_build_object('success', false, 'error', 'No se encontró ninguna operación anterior en el historial.'); \r\n        END IF;\r\n    ELSE\r\n        v_operacion_id_final := v_operacion_id_raw;\r\n    END IF;\r\n\r\n    -- 3. DETECTAR TIPO DE OPERACIÓN (VENTA_..., COMPRA_...)\r\n    v_tipo := split_part(v_operacion_id_final, '_', 1);\r\n\r\n    -- 4. ITERAR SOBRE LOS ÍTEMS A CORREGIR\r\n    -- El JSON trae: { items: [ { producto: \"...\", nuevo_precio: ... }, ... ] }\r\n    FOR rec_item IN SELECT * FROM jsonb_array_elements(p_input->'items')\r\n    LOOP\r\n        v_producto_busqueda := NULLIF(TRIM(rec_item.value->>'producto'), '');\r\n        v_nuevo_nombre      := NULLIF(TRIM(rec_item.value->>'nuevo_nombre'), '');\r\n        \r\n        -- Casteo seguro de números\r\n        BEGIN\r\n            v_nuevo_precio := (rec_item.value->>'nuevo_precio')::numeric;\r\n            v_nueva_cantidad := (rec_item.value->>'nueva_cantidad')::numeric;\r\n        EXCEPTION WHEN OTHERS THEN\r\n            v_nuevo_precio := NULL;\r\n            v_nueva_cantidad := NULL;\r\n        END;\r\n\r\n        IF v_producto_busqueda IS NOT NULL THEN\r\n            \r\n            -- LÓGICA VENTA\r\n            IF v_tipo = 'VENTA' THEN\r\n                -- Buscar ID del detalle (Búsqueda laxa pero priorizando exactitud)\r\n                SELECT id INTO v_item_id \r\n                FROM public.ventas_detalles \r\n                WHERE venta_id = v_operacion_id_final \r\n                  AND (producto ILIKE v_producto_busqueda OR producto ILIKE '%' || v_producto_busqueda || '%')\r\n                ORDER BY length(producto) ASC -- Priorizar el match más corto/exacto\r\n                LIMIT 1;\r\n\r\n                IF v_item_id IS NOT NULL THEN\r\n                    UPDATE public.ventas_detalles\r\n                    SET \r\n                        producto = COALESCE(v_nuevo_nombre, producto),\r\n                        precio_unitario = COALESCE(v_nuevo_precio, precio_unitario),\r\n                        cantidad = COALESCE(v_nueva_cantidad::int, cantidad),\r\n                        subtotal = (COALESCE(v_nueva_cantidad::int, cantidad) * COALESCE(v_nuevo_precio, precio_unitario))\r\n                    WHERE id = v_item_id;\r\n                    v_cambios_realizados := v_cambios_realizados + 1;\r\n                ELSE\r\n                    v_log_errores := v_log_errores || ' No encontré: ' || v_producto_busqueda || '.';\r\n                END IF;\r\n\r\n            -- LÓGICA COMPRA\r\n            ELSIF v_tipo = 'COMPRA' THEN\r\n                SELECT id INTO v_item_id \r\n                FROM public.compras_detalles \r\n                WHERE compra_id = v_operacion_id_final \r\n                  AND (producto ILIKE v_producto_busqueda OR producto ILIKE '%' || v_producto_busqueda || '%')\r\n                ORDER BY length(producto) ASC\r\n                LIMIT 1;\r\n\r\n                IF v_item_id IS NOT NULL THEN\r\n                    UPDATE public.compras_detalles\r\n                    SET \r\n                        producto = COALESCE(v_nuevo_nombre, producto),\r\n                        precio_unitario = COALESCE(v_nuevo_precio::text, precio_unitario),\r\n                        cantidad = COALESCE(v_nueva_cantidad, cantidad),\r\n                        -- Cálculo de subtotal en texto para compras\r\n                        subtotal = (COALESCE(v_nueva_cantidad, cantidad) * COALESCE(v_nuevo_precio, precio_unitario::numeric))::text\r\n                    WHERE id = v_item_id;\r\n                    v_cambios_realizados := v_cambios_realizados + 1;\r\n                ELSE\r\n                    v_log_errores := v_log_errores || ' No encontré: ' || v_producto_busqueda || '.';\r\n                END IF;\r\n            END IF;\r\n        END IF;\r\n    END LOOP;\r\n\r\n    -- 5. RECALCULO FINAL DE TOTALES\r\n    IF v_cambios_realizados > 0 THEN\r\n        IF v_tipo = 'VENTA' THEN\r\n            SELECT COALESCE(SUM(subtotal), 0) INTO v_total_recalculado \r\n            FROM public.ventas_detalles WHERE venta_id = v_operacion_id_final;\r\n\r\n            UPDATE public.ventas SET total_venta = v_total_recalculado::text WHERE venta_id = v_operacion_id_final;\r\n            \r\n            -- Actualizar movimientos de dinero solo si era Venta (Entrada)\r\n            UPDATE public.movimientos_dinero SET monto = v_total_recalculado::text \r\n            WHERE referencia_id = v_operacion_id_final AND tipo = 'ENTRADA';\r\n\r\n        ELSIF v_tipo = 'COMPRA' THEN\r\n            SELECT COALESCE(SUM(subtotal::numeric), 0) INTO v_total_recalculado \r\n            FROM public.compras_detalles WHERE compra_id = v_operacion_id_final;\r\n\r\n            UPDATE public.compras SET total_compra = v_total_recalculado::text WHERE compra_id = v_operacion_id_final;\r\n            \r\n            -- Actualizar movimientos de dinero solo si era Compra (Salida)\r\n            UPDATE public.movimientos_dinero SET monto = v_total_recalculado::text \r\n            WHERE referencia_id = v_operacion_id_final AND tipo = 'SALIDA';\r\n        END IF;\r\n\r\n        RETURN jsonb_build_object(\r\n            'success', true, \r\n            'mensaje', '✅ Corrección aplicada (' || v_cambios_realizados || ' ítems). Nuevo Total: $' || v_total_recalculado || '.' || v_log_errores\r\n        );\r\n    ELSE\r\n        RETURN jsonb_build_object(\r\n            'success', false, \r\n            'error', 'No se pudieron aplicar cambios. ' || v_log_errores\r\n        );\r\n    END IF;\r\n\r\nEXCEPTION WHEN OTHERS THEN\r\n    RETURN jsonb_build_object('success', false, 'error', 'Error SQL v10: ' || SQLERRM);\r\nEND;\r\n$function$\n"
  },
  {
    "nombre_funcion": "corregir_operacion_v17",
    "codigo_fuente": "CREATE OR REPLACE FUNCTION public.corregir_operacion_v17(p_input jsonb)\n RETURNS jsonb\n LANGUAGE plpgsql\nAS $function$\nDECLARE\n    v_input_norm jsonb;\n    v_id_final text;\n    v_id_upper text;\n    v_tipo text;\n    v_items_json jsonb;\n    v_pagos_json jsonb;\n    rec_item record;\n    v_item_id bigint;\n    v_old_n text; v_old_q numeric; v_old_p numeric;\n    v_new_n text; v_new_q numeric; v_new_p numeric;\n    rec_pago record;\n    v_mov_id text;\n    v_m_ant numeric; v_m_nue numeric;\n    v_met_ant text; v_met_nue text;\n    v_reporte_detallado text := '';\n    v_total_recal numeric := 0;\n    v_cambios_realizados int := 0;\n    v_salto text := chr(10);\n    v_cambios_ia jsonb := '[]'::jsonb;\n    v_item_cambio jsonb;\nBEGIN\n    v_input_norm := CASE WHEN jsonb_typeof(p_input) = 'array' THEN p_input->0 ELSE p_input END;\n    v_id_final := NULLIF(TRIM(v_input_norm->>'id_final'), '');\n    IF v_id_final IS NULL THEN RETURN jsonb_build_object('success', false, 'error', 'ID no especificado.'); END IF;\n    IF v_id_final = 'ULTIMA' THEN\n        SELECT operacion_id INTO v_id_final FROM public.historial_bot WHERE estado = 'EXITO' AND operacion_id IS NOT NULL ORDER BY log_id DESC LIMIT 1;\n        IF v_id_final IS NULL THEN RETURN jsonb_build_object('success', false, 'error', 'No hay historial.'); END IF;\n    END IF;\n    v_id_upper := UPPER(v_id_final);\n    v_tipo := split_part(v_id_upper, '_', 1);\n    v_reporte_detallado := '🛠️ *Corrección en ' || v_id_upper || '*' || v_salto;\n    v_items_json := v_input_norm->'items';\n    IF v_items_json IS NOT NULL AND jsonb_array_length(v_items_json) > 0 THEN\n        FOR rec_item IN SELECT * FROM jsonb_array_elements(v_items_json) LOOP\n            IF v_tipo IN ('RESERVA', 'RES') THEN\n                SELECT id, producto, cantidad, precio_unitario INTO v_item_id, v_old_n, v_old_q, v_old_p\n                FROM public.reservas_detalles \n                WHERE UPPER(reserva_id) = v_id_upper \n                  AND producto ILIKE '%' || TRIM(rec_item.value->>'producto') || '%' LIMIT 1;\n            ELSIF v_tipo = 'COMPRA' THEN\n                SELECT id, producto, cantidad, precio_unitario INTO v_item_id, v_old_n, v_old_q, v_old_p\n                FROM public.compras_detalles \n                WHERE UPPER(compra_id) = v_id_upper \n                  AND producto ILIKE '%' || TRIM(rec_item.value->>'producto') || '%' LIMIT 1;\n            ELSE \n                SELECT id, producto, cantidad::numeric, precio_unitario INTO v_item_id, v_old_n, v_old_q, v_old_p\n                FROM public.ventas_detalles \n                WHERE UPPER(venta_id) = v_id_upper \n                  AND producto ILIKE '%' || TRIM(rec_item.value->>'producto') || '%' LIMIT 1;\n            END IF;\n            IF v_item_id IS NOT NULL THEN\n                v_new_n := COALESCE(NULLIF(TRIM(rec_item.value->>'nuevo_nombre'), ''), v_old_n);\n                v_new_q := COALESCE((rec_item.value->>'nueva_cantidad')::numeric, v_old_q);\n                v_new_p := COALESCE((rec_item.value->>'nuevo_precio')::numeric, v_old_p);\n                IF (v_new_n != v_old_n OR v_new_q != v_old_q OR v_new_p != v_old_p) THEN\n                    v_item_cambio := jsonb_build_object(\n                        'producto_buscado', rec_item.value->>'producto',\n                        'antes', jsonb_build_object('nombre', v_old_n, 'cantidad', v_old_q, 'precio', v_old_p),\n                        'despues', jsonb_build_object('nombre', v_new_n, 'cantidad', v_new_q, 'precio', v_new_p)\n                    );\n                    v_cambios_ia := v_cambios_ia || v_item_cambio;\n                    v_reporte_detallado := v_reporte_detallado || v_salto || '📦 *' || v_old_n || '*:';\n                    IF v_new_n != v_old_n THEN v_reporte_detallado := v_reporte_detallado || v_salto || '  • Nombre: ' || v_old_n || ' ➔ ' || v_new_n; END IF;\n                    IF v_new_q != v_old_q THEN v_reporte_detallado := v_reporte_detallado || v_salto || '  • Cant: ' || v_old_q || ' ➔ ' || v_new_q; END IF;\n                    IF v_new_p != v_old_p THEN v_reporte_detallado := v_reporte_detallado || v_salto || '  • Precio: $' || v_old_p || ' ➔ $' || v_new_p; END IF;\n                    IF v_tipo IN ('RESERVA', 'RES') THEN\n                        UPDATE public.reservas_detalles SET producto = v_new_n, cantidad = v_new_q, precio_unitario = v_new_p, subtotal = (v_new_q * v_new_p) WHERE id = v_item_id;\n                    ELSIF v_tipo = 'COMPRA' THEN\n                        UPDATE public.compras_detalles SET producto = v_new_n, cantidad = v_new_q, precio_unitario = v_new_p, subtotal = (v_new_q * v_new_p) WHERE id = v_item_id;\n                    ELSE\n                        UPDATE public.ventas_detalles SET producto = v_new_n, cantidad = v_new_q::int, precio_unitario = v_new_p, subtotal = (v_new_q * v_new_p) WHERE id = v_item_id;\n                    END IF;\n                    UPDATE public.stock_movimientos SET producto = v_new_n WHERE UPPER(referencia_id) = v_id_upper AND producto = v_old_n;\n                    v_cambios_realizados := v_cambios_realizados + 1;\n                END IF;\n            END IF;\n        END LOOP;\n    END IF;\n    v_pagos_json := v_input_norm->'pagos';\n    IF v_pagos_json IS NOT NULL AND jsonb_array_length(v_pagos_json) > 0 THEN\n        FOR rec_pago IN SELECT * FROM jsonb_array_elements(v_pagos_json) LOOP\n            v_m_ant := (rec_pago.value->>'monto_anterior')::numeric;\n            v_m_nue := (rec_pago.value->>'nuevo_monto')::numeric;\n            v_met_nue := NULLIF(TRIM(rec_pago.value->>'nuevo_metodo'), '');\n            SELECT movimiento_id, metodo INTO v_mov_id, v_met_ant FROM public.movimientos_dinero\n            WHERE UPPER(referencia_id) = v_id_upper AND monto::numeric = v_m_ant ORDER BY fecha DESC LIMIT 1;\n            IF v_mov_id IS NOT NULL AND (v_m_nue != v_m_ant OR (v_met_nue IS NOT NULL AND v_met_nue != v_met_ant)) THEN\n                v_reporte_detallado := v_reporte_detallado || v_salto || v_salto || '💵 *Pago Corregido*:';\n                IF v_m_nue != v_m_ant THEN v_reporte_detallado := v_reporte_detallado || v_salto || '  • Monto: $' || v_m_ant || ' ➔ $' || v_m_nue; END IF;\n                IF v_met_nue IS NOT NULL AND v_met_nue != v_met_ant THEN v_reporte_detallado := v_reporte_detallado || v_salto || '  • Método: ' || v_met_ant || ' ➔ ' || v_met_nue; END IF;\n                IF v_m_nue = 0 THEN DELETE FROM public.movimientos_dinero WHERE movimiento_id = v_mov_id;\n                ELSE UPDATE public.movimientos_dinero SET monto = v_m_nue, metodo = COALESCE(v_met_nue, metodo) WHERE movimiento_id = v_mov_id;\n                END IF;\n                v_cambios_realizados := v_cambios_realizados + 1;\n            END IF;\n        END LOOP;\n    END IF;\n    IF v_tipo IN ('RESERVA', 'RES') THEN\n        PERFORM public.recalcular_reserva(v_id_final); \n        SELECT saldo_pendiente INTO v_total_recal FROM public.reservas WHERE UPPER(reserva_id) = v_id_upper;\n        v_reporte_detallado := v_reporte_detallado || v_salto || v_salto || '💰 *Nuevo Saldo Pendiente: $' || v_total_recal || '*';\n    ELSIF v_tipo = 'COMPRA' THEN\n        SELECT SUM(subtotal::numeric) INTO v_total_recal FROM public.compras_detalles WHERE UPPER(compra_id) = v_id_upper;\n        UPDATE public.compras SET total_compra = v_total_recal WHERE UPPER(compra_id) = v_id_upper;\n        v_reporte_detallado := v_reporte_detallado || v_salto || v_salto || '💰 *Nuevo Total Compra: $' || v_total_recal || '*';\n    ELSE\n        SELECT COALESCE(SUM(subtotal), 0) INTO v_total_recal FROM public.ventas_detalles WHERE UPPER(venta_id) = v_id_upper;\n        UPDATE public.ventas SET total_venta = v_total_recal WHERE UPPER(venta_id) = v_id_upper;\n        v_reporte_detallado := v_reporte_detallado || v_salto || v_salto || '💰 *Nuevo Total Venta: $' || v_total_recal || '*';\n    END IF;\n    IF v_cambios_realizados = 0 THEN\n        v_reporte_detallado := '⚠️ No se detectaron productos o pagos coincidentes para ' || v_id_upper || '.';\n    END IF;\n    RETURN jsonb_build_object(\n        'success', true, \n        'mensaje', v_reporte_detallado,\n        'detalles', jsonb_build_object(\n            'items', v_cambios_realizados,\n            'pagos', v_cambios_realizados,\n            'id', v_id_upper\n        ),\n        'aprendizaje_data', jsonb_build_object(\n            'cambios', v_cambios_ia\n        )\n    );\nEND;\n$function$\n"
  },
  {
    "nombre_funcion": "fn_buscar_productos_similares",
    "codigo_fuente": "CREATE OR REPLACE FUNCTION public.fn_buscar_productos_similares(p_search text)\n RETURNS TABLE(nombre text, precio numeric, similitud real)\n LANGUAGE plpgsql\n SECURITY DEFINER\nAS $function$\n    DECLARE\n        v_search text;\n        v_nombre_sinonimo text;\n    BEGIN\n        v_search := public.normalizar_texto(p_search);\n\n        -- Paso 1: Match exacto de alias en tabla de sinonimos\n        SELECT ps.nombre_oficial INTO v_nombre_sinonimo\n        FROM public.productos_sinonimos ps\n        WHERE ps.alias = v_search\n        LIMIT 1;\n\n        IF v_nombre_sinonimo IS NOT NULL THEN\n            RETURN QUERY\n            SELECT pb.nombre, pb.ultimo_precio_venta, 1.0::real\n            FROM public.productos_base pb\n            WHERE pb.nombre = v_nombre_sinonimo\n            LIMIT 1;\n            RETURN;\n        END IF;\n\n        -- Paso 2: El input contiene un alias conocido (match parcial)\n        SELECT ps.nombre_oficial INTO v_nombre_sinonimo\n        FROM public.productos_sinonimos ps\n        WHERE v_search LIKE '%' || ps.alias || '%'\n        ORDER BY length(ps.alias) DESC\n        LIMIT 1;\n\n        IF v_nombre_sinonimo IS NOT NULL THEN\n            RETURN QUERY\n            SELECT pb.nombre, pb.ultimo_precio_venta, 0.95::real\n            FROM public.productos_base pb\n            WHERE pb.nombre = v_nombre_sinonimo\n            LIMIT 1;\n            RETURN;\n        END IF;\n\n        -- Paso 3: Fallback pg_trgm con input normalizado\n        RETURN QUERY\n        SELECT \n            pb.nombre,\n            pb.ultimo_precio_venta,\n            similarity(pb.nombre, v_search)\n        FROM public.productos_base pb\n        WHERE \n            pb.nombre % v_search\n            OR pb.nombre ILIKE '%' || v_search || '%'\n        ORDER BY similarity(pb.nombre, v_search) DESC\n        LIMIT 15;\n    END;\n    $function$\n"
  },
  {
    "nombre_funcion": "actualizar_producto_global",
    "codigo_fuente": "CREATE OR REPLACE FUNCTION public.actualizar_producto_global(p_id bigint, p_nuevo_nombre text, p_nuevo_precio_venta numeric, p_nuevo_costo_compra numeric, p_nuevo_stock integer)\n RETURNS jsonb\n LANGUAGE plpgsql\nAS $function$ DECLARE v_nombre_viejo text; v_stock_viejo integer; v_id_destino bigint; v_diferencia_stock integer; BEGIN SELECT nombre, stock_actual INTO v_nombre_viejo, v_stock_viejo FROM public.productos WHERE producto_id = p_id; IF v_nombre_viejo IS NULL THEN RETURN jsonb_build_object('success', false, 'error', 'Producto no encontrado'); END IF; IF v_nombre_viejo <> p_nuevo_nombre THEN SELECT producto_id INTO v_id_destino FROM public.productos WHERE nombre = p_nuevo_nombre AND producto_id <> p_id; IF v_id_destino IS NOT NULL THEN UPDATE public.ventas_detalles SET producto = p_nuevo_nombre WHERE producto = v_nombre_viejo; UPDATE public.compras_detalles SET producto = p_nuevo_nombre WHERE producto = v_nombre_viejo; UPDATE public.reservas_detalles SET producto = p_nuevo_nombre WHERE producto = v_nombre_viejo; UPDATE public.stock_movimientos SET producto = p_nuevo_nombre WHERE producto = v_nombre_viejo; UPDATE public.productos SET stock_actual = stock_actual + v_stock_viejo, fecha_actualizacion = now() WHERE producto_id = v_id_destino; DELETE FROM public.productos WHERE producto_id = p_id; RETURN jsonb_build_object('success', true, 'mensaje', 'Productos unificados con exito.', 'tipo_accion', 'MERGE', 'id_eliminado', p_id, 'id_destino', v_id_destino); END IF; END IF; v_diferencia_stock := p_nuevo_stock - v_stock_viejo; UPDATE public.productos SET nombre = p_nuevo_nombre, ultimo_precio_venta = p_nuevo_precio_venta, ultimo_costo_compra = p_nuevo_costo_compra, stock_actual = p_nuevo_stock, fecha_actualizacion = now() WHERE producto_id = p_id; IF v_diferencia_stock <> 0 THEN INSERT INTO public.stock_movimientos (movimiento_id, fecha, producto, cantidad, referencia_tipo, referencia_id, notas) VALUES ('REC_' || p_id || '_' || extract(epoch from now())::bigint, now(), p_nuevo_nombre, v_diferencia_stock, 'RECUENTO', 'PROD_' || p_id, 'Ajuste manual de stock (Recuento)'); END IF; IF v_nombre_viejo <> p_nuevo_nombre THEN UPDATE public.ventas_detalles SET producto = p_nuevo_nombre WHERE producto = v_nombre_viejo; UPDATE public.compras_detalles SET producto = p_nuevo_nombre WHERE producto = v_nombre_viejo; UPDATE public.reservas_detalles SET producto = p_nuevo_nombre WHERE producto = v_nombre_viejo; UPDATE public.stock_movimientos SET producto = p_nuevo_nombre WHERE producto = v_nombre_viejo; END IF; RETURN jsonb_build_object('success', true, 'mensaje', 'Producto actualizado correctamente.', 'tipo_accion', 'UPDATE', 'renombrado', (v_nombre_viejo <> p_nuevo_nombre), 'ajuste_stock', v_diferencia_stock); EXCEPTION WHEN OTHERS THEN RETURN jsonb_build_object('success', false, 'error', SQLERRM); END; $function$\n"
  },
  {
    "nombre_funcion": "fn_buscar_productos_por_unidades",
    "codigo_fuente": "CREATE OR REPLACE FUNCTION public.fn_buscar_productos_por_unidades(p_patron_numero text DEFAULT NULL::text)\n RETURNS TABLE(nombre text, stock_actual integer, ultimo_precio numeric)\n LANGUAGE plpgsql\nAS $function$\r\nBEGIN\r\n    RETURN QUERY\r\n    SELECT p.nombre, p.stock_actual, p.ultimo_precio_venta\r\n    FROM public.productos p\r\n    WHERE p.nombre ~* ('x' || COALESCE(p_patron_numero, '[0-9]+'))\r\n    ORDER BY p.nombre ASC;\r\nEND;\r\n$function$\n"
  },
  {
    "nombre_funcion": "actualizar_producto_global_v2",
    "codigo_fuente": "CREATE OR REPLACE FUNCTION public.actualizar_producto_global_v2(p_id bigint, p_nuevo_nombre text, p_nuevo_precio_venta numeric, p_nuevo_costo_compra numeric, p_nuevo_stock integer)\n RETURNS jsonb\n LANGUAGE plpgsql\nAS $function$\nDECLARE\n    v_nombre_viejo text;\n    v_stock_actual_calculado integer;\n    v_id_destino bigint;\n    v_diferencia_stock integer;\n    v_nombre_norm text;\nBEGIN\n    -- 1. Obtener el nombre actual del producto antes del cambio\n    SELECT nombre INTO v_nombre_viejo \n    FROM public.productos_base \n    WHERE producto_id = p_id;\n\n    IF v_nombre_viejo IS NULL THEN\n        RETURN jsonb_build_object('success', false, 'error', 'Producto no encontrado en productos_base');\n    END IF;\n\n    v_nombre_norm := public.normalizar_texto(p_nuevo_nombre);\n\n    -- Desactivar triggers para evitar recursividad o efectos secundarios no deseados durante la unificación\n    PERFORM set_config('app.bypass_triggers', 'true', true);\n\n    -- 2. Verificar si es una unificación (si el nuevo nombre ya existe en otro ID)\n    IF v_nombre_viejo <> v_nombre_norm THEN\n        SELECT producto_id INTO v_id_destino \n        FROM public.productos_base \n        WHERE nombre = v_nombre_norm AND producto_id <> p_id;\n\n        IF v_id_destino IS NOT NULL THEN\n            -- CASO A: FUSIÓN DE PRODUCTOS\n            \n            -- ACTUALIZAR HISTORIAL USANDO NORMALIZACIÓN (FIX: captura variantes de casing/espacios)\n            UPDATE public.ventas_detalles SET producto = v_nombre_norm WHERE public.normalizar_texto(producto) = v_nombre_viejo;\n            UPDATE public.compras_detalles SET producto = v_nombre_norm WHERE public.normalizar_texto(producto) = v_nombre_viejo;\n            UPDATE public.reservas_detalles SET producto = v_nombre_norm WHERE public.normalizar_texto(producto) = v_nombre_viejo;\n            \n            -- Actualizar movimientos de stock: sumar si ya existe el destino en la misma operación\n            UPDATE public.stock_movimientos s\n            SET cantidad = s.cantidad + a.cantidad\n            FROM (\n                SELECT referencia_tipo, referencia_id, cantidad \n                FROM public.stock_movimientos \n                WHERE public.normalizar_texto(producto) = v_nombre_viejo\n            ) a\n            WHERE s.referencia_tipo = a.referencia_tipo \n              AND s.referencia_id = a.referencia_id \n              AND s.producto = v_nombre_norm;\n\n            -- Eliminar los movimientos que acabamos de sumar para evitar duplicidad\n            DELETE FROM public.stock_movimientos s\n            WHERE public.normalizar_texto(producto) = v_nombre_viejo \n              AND EXISTS (\n                  SELECT 1 FROM public.stock_movimientos s2 \n                  WHERE s2.referencia_tipo = s.referencia_tipo \n                    AND s2.referencia_id = s.referencia_id \n                    AND s2.producto = v_nombre_norm\n              );\n\n            -- Renombrar los movimientos que no tenían contraparte\n            UPDATE public.stock_movimientos SET producto = v_nombre_norm WHERE public.normalizar_texto(producto) = v_nombre_viejo;\n            \n            -- Eliminar el producto viejo del catálogo principal\n            DELETE FROM public.productos_base WHERE producto_id = p_id;\n\n            -- APRENDIZAJE AUTOMÁTICO: guardar nombre viejo como sinónimo del nuevo para futuras operaciones\n            INSERT INTO public.productos_sinonimos (alias, nombre_oficial)\n            VALUES (v_nombre_viejo, v_nombre_norm)\n            ON CONFLICT (alias) DO UPDATE SET nombre_oficial = EXCLUDED.nombre_oficial;\n\n            PERFORM set_config('app.bypass_triggers', 'false', true);\n\n            RETURN jsonb_build_object(\n                'success', true, \n                'mensaje', 'Productos unificados con éxito. El historial se movió a ' || v_nombre_norm,\n                'tipo_accion', 'MERGE',\n                'id_eliminado', p_id,\n                'id_destino', v_id_destino\n            );\n        END IF;\n    END IF;\n\n    -- CASO B: ACTUALIZACIÓN SIMPLE O RENOMBRADO SIN CONFLICTO\n    \n    -- Calcular stock actual basado en movimientos (usando normalización para ser precisos)\n    SELECT COALESCE(SUM(cantidad), 0)::integer INTO v_stock_actual_calculado \n    FROM public.stock_movimientos \n    WHERE public.normalizar_texto(producto) = v_nombre_viejo;\n\n    v_diferencia_stock := p_nuevo_stock - v_stock_actual_calculado;\n\n    -- Actualizar el producto en el catálogo\n    UPDATE public.productos_base \n    SET nombre = v_nombre_norm,\n        ultimo_precio_venta = p_nuevo_precio_venta,\n        ultimo_costo_compra = p_nuevo_costo_compra,\n        fecha_actualizacion = now()\n    WHERE producto_id = p_id;\n\n    -- Si cambió el nombre, actualizar el historial también\n    IF v_nombre_viejo <> v_nombre_norm THEN\n        UPDATE public.ventas_detalles SET producto = v_nombre_norm WHERE public.normalizar_texto(producto) = v_nombre_viejo;\n        UPDATE public.compras_detalles SET producto = v_nombre_norm WHERE public.normalizar_texto(producto) = v_nombre_viejo;\n        UPDATE public.reservas_detalles SET producto = v_nombre_norm WHERE public.normalizar_texto(producto) = v_nombre_viejo;\n        \n        -- Mismo proceso de ajuste para movimientos de stock\n        UPDATE public.stock_movimientos s\n        SET cantidad = s.cantidad + a.cantidad\n        FROM (\n            SELECT referencia_tipo, referencia_id, cantidad \n            FROM public.stock_movimientos \n            WHERE public.normalizar_texto(producto) = v_nombre_viejo\n        ) a\n        WHERE s.referencia_tipo = a.referencia_tipo \n          AND s.referencia_id = a.referencia_id \n          AND s.producto = v_nombre_norm;\n\n        DELETE FROM public.stock_movimientos s\n        WHERE public.normalizar_texto(producto) = v_nombre_viejo \n          AND EXISTS (\n              SELECT 1 FROM public.stock_movimientos s2 \n              WHERE s2.referencia_tipo = s.referencia_tipo \n                AND s2.referencia_id = s.referencia_id \n                AND s2.producto = v_nombre_norm\n          );\n\n        UPDATE public.stock_movimientos SET producto = v_nombre_norm WHERE public.normalizar_texto(producto) = v_nombre_viejo;\n\n        -- Registrar sinónimo\n        INSERT INTO public.productos_sinonimos (alias, nombre_oficial)\n        VALUES (v_nombre_viejo, v_nombre_norm)\n        ON CONFLICT (alias) DO UPDATE SET nombre_oficial = EXCLUDED.nombre_oficial;\n    END IF;\n\n    -- Si hubo ajuste de stock manual, registrar un movimiento de RECUENTO\n    IF v_diferencia_stock <> 0 THEN\n        INSERT INTO public.stock_movimientos (\n            movimiento_id, fecha, producto, cantidad, referencia_tipo, referencia_id, notas\n        ) VALUES (\n            'REC_' || p_id || '_' || extract(epoch from now())::bigint,\n            now(),\n            v_nombre_norm,\n            v_diferencia_stock,\n            'RECUENTO',\n            'REC_' || p_id || '_' || floor(extract(epoch from now()) * 1000)::text,\n            'Ajuste manual desde Dashboard'\n        );\n    END IF;\n\n    PERFORM set_config('app.bypass_triggers', 'false', true);\n\n    RETURN jsonb_build_object(\n        'success', true, \n        'mensaje', 'Producto actualizado correctamente.',\n        'tipo_accion', 'UPDATE',\n        'renombrado', (v_nombre_viejo <> v_nombre_norm),\n        'ajuste_stock', v_diferencia_stock\n    );\n\nEXCEPTION WHEN OTHERS THEN\n    PERFORM set_config('app.bypass_triggers', 'false', true);\n    RETURN jsonb_build_object('success', false, 'error', SQLERRM);\nEND;\n$function$\n"
  },
  {
    "nombre_funcion": "fn_productos_view_insert",
    "codigo_fuente": "CREATE OR REPLACE FUNCTION public.fn_productos_view_insert()\n RETURNS trigger\n LANGUAGE plpgsql\nAS $function$ BEGIN INSERT INTO public.productos_base (nombre, ultimo_precio_venta, ultimo_costo_compra, fecha_actualizacion) VALUES (NEW.nombre, NEW.ultimo_precio_venta, NEW.ultimo_costo_compra, COALESCE(NEW.fecha_actualizacion, NOW())); RETURN NEW; END; $function$\n"
  },
