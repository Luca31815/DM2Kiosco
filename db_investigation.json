    "nombre_funcion": "fn_productos_view_update",
    "codigo_fuente": "CREATE OR REPLACE FUNCTION public.fn_productos_view_update()\n RETURNS trigger\n LANGUAGE plpgsql\nAS $function$ BEGIN UPDATE public.productos_base SET nombre = NEW.nombre, ultimo_precio_venta = NEW.ultimo_precio_venta, ultimo_costo_compra = NEW.ultimo_costo_compra, fecha_actualizacion = NOW() WHERE producto_id = OLD.producto_id; RETURN NEW; END; $function$\n"
